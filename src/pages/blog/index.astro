---
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const slugify = (value: string) =>
	value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');

const categories = [...new Set(posts.flatMap((p) => p.data.categories))];
const tags = [...new Set(posts.flatMap((p) => p.data.tags ?? []))];
const categoryCounts = categories.reduce(
	(acc, cat) => {
		acc[cat] = posts.filter((p) => p.data.categories.includes(cat)).length;
		return acc;
	},
	{} as Record<string, number>,
);

// Recent for sidebar (cap at 5 for scale)
const recentPosts = [...posts]
	.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
	.slice(0, 5);

// Series: compact list for scale
const seriesMap = posts
	.filter((p) => p.data.series)
	.reduce(
		(acc, post) => {
			const name = post.data.series!;
			if (!acc[name]) acc[name] = [];
			acc[name].push(post);
			return acc;
		},
		{} as Record<string, typeof posts>,
	);
Object.values(seriesMap).forEach((arr) =>
	arr.sort((a, b) => (a.data.seriesPart ?? 0) - (b.data.seriesPart ?? 0)),
);
const seriesEntries = Object.entries(seriesMap)
	.map(([name, seriesPosts]) => ({
		name,
		posts: seriesPosts,
		first: seriesPosts[0],
		count: seriesPosts.length,
	}))
	.sort(
		(a, b) =>
			(b.posts[b.posts.length - 1]?.data.publishDate?.getTime() ?? 0) -
			(a.posts[a.posts.length - 1]?.data.publishDate?.getTime() ?? 0),
	);

// All posts: non-series posts first, then featured, then by date
const allPostsSorted = [...posts].sort((a, b) => {
	const aSeries = a.data.series ? 1 : 0;
	const bSeries = b.data.series ? 1 : 0;
	if (aSeries !== bSeries) return aSeries - bSeries;
	if (Number(b.data.featured) !== Number(a.data.featured)) {
		return Number(b.data.featured) - Number(a.data.featured);
	}
	return b.data.publishDate.getTime() - a.data.publishDate.getTime();
});

const POSTS_PER_PAGE = 12;
const totalPages = Math.max(1, Math.ceil(allPostsSorted.length / POSTS_PER_PAGE));
const currentPage: number = 1;
const postsForPage = allPostsSorted.slice(0, POSTS_PER_PAGE);

const SIDEBAR_TAGS_SHOW = 15;
const tagsPreview = tags.slice(0, SIDEBAR_TAGS_SHOW);
const tagsMore = tags.length > SIDEBAR_TAGS_SHOW;

const site = Astro.site?.toString() ?? 'https://dhruvverma.dev';
const blogSchema = {
	'@context': 'https://schema.org',
	'@type': 'Blog',
	'@id': new URL('/blog', site).toString(),
	name: 'Dhruv Verma Blog',
	description: 'Articles and tutorials on Node.js, React, TypeScript, and building products.',
	url: new URL('/blog', site).toString(),
	mainEntity: {
		'@type': 'ItemList',
		numberOfItems: posts.length,
		itemListElement: posts
			.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
			.slice(0, 20)
			.map((p, i) => ({
				'@type': 'ListItem',
				position: i + 1,
				url: new URL(`/blog/${p.slug}`, site).toString(),
				name: p.data.title,
				datePublished: p.data.publishDate.toISOString(),
			})),
	},
};
---

<Layout
	title='Blog - Dhruv Verma | Writing on Node.js, React & Product'
	description='Articles and tutorials on Node.js, React, TypeScript, and building products. By Dhruv Verma.'
>
	<script type='application/ld+json' set:html={JSON.stringify(blogSchema)} />
	<div class='container mx-auto py-16'>
		<h1 class='sr-only'>Blog</h1>
		<div class='grid grid-cols-1 lg:grid-cols-[260px_1fr] gap-12'>
			<aside class='space-y-8' aria-label='Blog categories and navigation'>
				<div class='bg-surface/70 rounded-2xl p-6 border border-border/70'>
					<h2 class='text-lg font-semibold mb-4'>Categories</h2>
					<ul class='space-y-2 max-h-48 overflow-y-auto'>
						{categories.map((category) => (
							<li>
								<span class='text-sm text-muted flex items-center justify-between'>
									<span>{category}</span>
									<span class='text-xs bg-surface border border-border/70 text-muted px-2 py-1 rounded-full'>
										{categoryCounts[category]}
									</span>
								</span>
							</li>
						))}
					</ul>
				</div>
				<div class='bg-surface/70 rounded-2xl p-6 border border-border/70'>
					<h2 class='text-lg font-semibold mb-4'>Recent posts</h2>
					<ul class='space-y-4'>
						{recentPosts.map((post) => (
							<li>
								<a href={`/blog/${post.slug}`} class='group block'>
									<h3 class='text-sm font-medium group-hover:text-ink transition-colors line-clamp-2'>
										{post.data.title}
									</h3>
									<p class='text-xs text-muted mt-0.5'>
										{new Date(post.data.publishDate).toLocaleDateString('en-US', {
											month: 'short',
											day: 'numeric',
											year: 'numeric',
										})}
									</p>
								</a>
							</li>
						))}
					</ul>
					{totalPages > 1 && (
						<a
							href='/blog/page/2'
							class='mt-4 inline-block text-sm font-medium text-accent hover:text-accentStrong'
						>
							All posts →
						</a>
					)}
				</div>
				<div class='bg-surface/70 rounded-2xl p-6 border border-border/70'>
					<h2 class='text-lg font-semibold mb-4'>Tags</h2>
					<div class='flex flex-wrap gap-2'>
						{tagsPreview.map((tag) => (
							<a
								href={`/blog/tag/${slugify(tag)}`}
								class='text-xs px-3 py-1 rounded-full border border-border/70 text-muted hover:text-ink hover:border-accent transition-colors'
							>
								{tag}
							</a>
						))}
					</div>
					{tagsMore && (
						<details class='mt-3'>
							<summary class='cursor-pointer text-xs text-muted hover:text-ink transition-colors'>Show more tags</summary>
							<div class='flex flex-wrap gap-2 mt-2'>
								{tags.slice(SIDEBAR_TAGS_SHOW).map((tag) => (
									<a
										href={`/blog/tag/${slugify(tag)}`}
										class='text-xs px-3 py-1 rounded-full border border-border/70 text-muted hover:text-ink hover:border-accent transition-colors'
									>
										{tag}
									</a>
								))}
							</div>
						</details>
					)}
				</div>
			</aside>

			<div class='space-y-16 min-w-0'>
				{/* 1. Series first - prominent showcase for curated multi-part content */}
				{seriesEntries.length > 0 && (
					<section aria-label='Series'>
						<h2 class='text-xl md:text-2xl font-semibold font-display mb-6'>Series</h2>
						<div class={seriesEntries.length > 1 ? 'grid gap-6 sm:grid-cols-2' : 'grid gap-6'}>
							{seriesEntries.map((entry) => (
								<div class='rounded-2xl border border-border/70 bg-surface/70 p-6 hover:border-accent/60 transition-colors'>
									<div class='flex items-center justify-between gap-4 mb-4'>
										<span class='text-xl font-display font-semibold'>{entry.name}</span>
										<span class='text-xs border border-border/70 text-muted px-2 py-1 rounded-full flex-shrink-0'>
											{entry.count} part{entry.count !== 1 ? 's' : ''}
										</span>
									</div>
									<ol class='space-y-0'>
										{entry.posts.map((post) => (
											<li>
												<a
													href={`/blog/${post.slug}`}
													class='group flex items-baseline gap-3 py-1.5 hover:text-ink transition-colors'
												>
													<span class='font-mono text-xs text-muted flex-shrink-0'>
														Part {post.data.seriesPart}
													</span>
													<span class='text-sm font-medium text-muted group-hover:text-ink transition-colors'>
														{post.data.title}
													</span>
												</a>
											</li>
										))}
									</ol>
								</div>
							))}
						</div>
					</section>
				)}

				{/* 2. All posts grid */}
				<section aria-label='Blog posts'>
					<div class='flex items-center justify-between gap-4 mb-6 flex-wrap'>
						<h2 class='text-xl md:text-2xl font-semibold font-display' id='posts-heading'>All posts</h2>
						<span class='text-sm text-muted flex items-center gap-3'>
							{allPostsSorted.length} post{allPostsSorted.length !== 1 ? 's' : ''}
							<a href='/feed.xml' class='text-accent hover:text-accentStrong transition-colors' aria-label='Subscribe to RSS feed'>RSS</a>
						</span>
					</div>
					<div class='grid gap-8 sm:grid-cols-2'>
						{postsForPage.map((post) => (
							<BlogCard post={post} />
						))}
					</div>
					{!postsForPage.length && (
						<p class='text-sm text-muted'>No posts yet.</p>
					)}
					{/* Pagination */}
					{totalPages > 1 && (
						<nav class='mt-10 flex items-center justify-center gap-4' aria-label='Posts pagination'>
							{currentPage > 1 ? (
								<a
									href={currentPage === 2 ? '/blog' : `/blog/page/${currentPage - 1}`}
									class='text-sm font-medium text-accent hover:text-accentStrong'
								>
									← Newer
								</a>
							) : (
								<span />
							)}
							<span class='text-sm text-muted'>
								Page {currentPage} of {totalPages}
							</span>
							{currentPage < totalPages ? (
								<a
									href={`/blog/page/${currentPage + 1}`}
									class='text-sm font-medium text-accent hover:text-accentStrong'
								>
									Older →
								</a>
							) : (
								<span />
							)}
						</nav>
					)}
				</section>
			</div>
		</div>
	</div>
</Layout>
