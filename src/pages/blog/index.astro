---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const categories = [...new Set(posts.flatMap((post) => post.data.categories))];
const tags = [
	...new Set(
		posts.flatMap((post) => (post.data.tags ? post.data.tags : []))
	),
];

const slugify = (value: string) =>
	value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');

// Group posts by category
const postsByCategory = categories.reduce(
	(acc, category) => {
		acc[category] = posts.filter((post) =>
			post.data.categories.includes(category)
		);
		return acc;
	},
	{} as Record<string, typeof posts>
);

// Get recent posts
const recentPosts = [...posts]
	.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
	.slice(0, 3);

// Get series (assuming we add a series field to frontmatter)
const series = posts
	.filter((post) => post.data.series)
	.reduce((acc, post) => {
		const seriesName = post.data.series;
		if (!acc[seriesName]) {
			acc[seriesName] = [];
		}
		acc[seriesName].push(post);
		return acc;
	}, {});

// Sort series posts by part number
Object.values(series).forEach((seriesPosts: typeof posts) => {
	seriesPosts.sort((a, b) => a.data.seriesPart - b.data.seriesPart);
});
---

<Layout title='Blog - Dhruv Verma'>
	<div class='container mx-auto py-16'>
		<div class='grid grid-cols-1 lg:grid-cols-[260px_1fr] gap-12'>
			{/* Sidebar Navigation */}
			<aside class='space-y-8'>
				{/* Categories */}
				<div class='bg-surface/70 rounded-2xl p-6 border border-border/70'>
					<h2 class='text-lg font-semibold mb-4'>Categories</h2>
					<ul class='space-y-2'>
						{
							categories.map((category) => (
								<li>
									<a
										href={`#${slugify(category)}`}
										class='text-sm text-muted hover:text-ink flex items-center justify-between'
									>
										<span>{category}</span>
										<span class='text-xs bg-surface border border-border/70 text-muted px-2 py-1 rounded-full'>
											{postsByCategory[category].length}
										</span>
									</a>
								</li>
							))
						}
					</ul>
				</div>

				{/* Recent Posts */}
				<div class='bg-surface/70 rounded-2xl p-6 border border-border/70'>
					<h2 class='text-lg font-semibold mb-4'>Recent posts</h2>
					<ul class='space-y-4'>
						{
							recentPosts.map((post) => (
								<li>
									<a href={`/blog/${post.slug}`} class='group block'>
										<h3 class='text-sm font-medium group-hover:text-ink transition-colors'>
											{post.data.title}
										</h3>
										<p class='text-xs text-muted'>
											{new Date(post.data.publishDate).toLocaleDateString()}
										</p>
									</a>
								</li>
							))
						}
					</ul>
				</div>

				{/* Tags */}
				<div class='bg-surface/70 rounded-2xl p-6 border border-border/70'>
					<h2 class='text-lg font-semibold mb-4'>Tags</h2>
					<div class='flex flex-wrap gap-2'>
						{tags.map((tag) => (
							<a
								href={`/blog/tag/${slugify(tag)}`}
								class='text-xs px-3 py-1 rounded-full border border-border/70 text-muted hover:text-ink hover:border-accent transition-colors'
							>
								{tag}
							</a>
						))}
					</div>
				</div>
			</aside>

			{/* Main Content */}
			<div class='space-y-16'>
				{/* Series Section */}
				{
					Object.keys(series).length > 0 && (
						<section>
							<h2 class='text-2xl md:text-3xl font-semibold font-display mb-8'>
								Series
							</h2>
							<div class='grid gap-8 md:grid-cols-2'>
								{Object.entries(series).map(([seriesName, posts]) => (
									<div class='bg-surface/70 rounded-2xl p-6 border border-border/70'>
										<h3 class='text-lg font-semibold mb-4'>{seriesName}</h3>
										<ul class='space-y-3'>
											{(posts as any[]).map((post, index) => (
												<li>
													<a
														href={`/blog/${post.slug}`}
														class='group flex items-center gap-3'
													>
														<span class='flex-shrink-0 w-6 h-6 flex items-center justify-center border border-border/70 text-muted rounded-full text-xs'>
															{index + 1}
														</span>
														<span class='group-hover:text-ink transition-colors text-sm'>
															{post.data.title}
														</span>
													</a>
												</li>
											))}
										</ul>
									</div>
								))}
							</div>
						</section>
					)
				}

				{/* Categories and Posts */}
				{
					categories.map((category) => (
						<section id={slugify(category)}>
							<div class='flex items-center gap-3 mb-6'>
								<h2 class='text-xl md:text-2xl font-semibold font-display'>
									{category}
								</h2>
								<span class='text-xs text-muted'>
									{postsByCategory[category].length} posts
								</span>
							</div>
							<div class='grid gap-8 md:grid-cols-2 lg:grid-cols-2'>
								{postsByCategory[category].map((post) => (
									<a
										href={`/blog/${post.slug}`}
										class='group bg-surface/70 rounded-2xl overflow-hidden border border-border/70 hover:border-accent/60 transition-all duration-300'
									>
										{post.data.image && (
											<div class='aspect-video overflow-hidden'>
												<img
													src={post.data.image}
													alt={post.data.title}
													class='w-full h-full object-cover group-hover:scale-105 transition-transform duration-300'
												/>
											</div>
										)}
										<div class='p-6'>
											<div class='flex flex-wrap gap-1.5 mb-4 items-center'>
												{(post.data.categories as string[])
													.slice(0, 2)
													.map((cat) => (
														<span class='border border-border/70 text-muted px-2 py-0.5 rounded-full text-xs font-medium leading-tight'>
															{cat}
														</span>
													))}
												{(post.data.categories as string[]).length > 2 && (
													<span class='text-xs text-muted'>
														+{(post.data.categories as string[]).length - 2}{' '}
														more
													</span>
												)}
											</div>
											<h3 class='text-lg font-semibold mb-3 group-hover:text-ink transition-colors line-clamp-2'>
												{post.data.title}
											</h3>
											<p class='text-sm text-muted mb-4 line-clamp-3 leading-relaxed'>
												{post.data.excerpt}
											</p>
											<div class='flex justify-between items-center'>
												<span class='text-xs text-muted'>
													{new Date(post.data.publishDate).toLocaleDateString(
														'en-US',
														{
															year: 'numeric',
															month: 'short',
															day: 'numeric',
														}
													)}
												</span>
												<span class='sr-only'>Read more</span>
												<span class='text-accent group-hover:translate-x-1 transition-transform text-sm font-medium'>
													→
												</span>
											</div>
										</div>
									</a>
								))}
							</div>
						</section>
					))
				}
			</div>
		</div>
	</div>
</Layout>
