---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const slugify = (v: string) =>
		v
			.toLowerCase()
			.replace(/[^a-z0-9]+/g, '-')
			.replace(/(^-|-$)/g, '');
	const posts = await getCollection('blog');
	const tagMap = posts.reduce(
		(acc, post) => {
			(post.data.tags || []).forEach((tag) => {
				const slug = slugify(tag);
				if (!acc[slug]) {
					acc[slug] = { tag, posts: [] };
				}
				acc[slug].posts.push(post);
			});
			return acc;
		},
		{} as Record<string, { tag: string; posts: typeof posts }>,
	);

	return Object.entries(tagMap).map(([slug, data]) => ({
		params: { tag: slug },
		props: { tag: data.tag, posts: data.posts },
	}));
}

const { tag, posts: tagPosts } = Astro.props;
const sortedPosts = [...tagPosts].sort(
	(a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);
---

<Layout
	title={`Tag: ${tag} - Dhruv Verma`}
	description={`Posts tagged '${tag}'. By Dhruv Verma.`}
>
	<section class='py-16'>
		<div class='container mx-auto'>
			<p class='font-mono text-sm uppercase tracking-[0.12em] text-muted'>Tag</p>
			<h1 class='text-3xl md:text-5xl font-semibold font-display mt-4'>
				{tag}
			</h1>
			<p class='text-sm text-muted mt-3'>
				{tagPosts.length} post{tagPosts.length === 1 ? '' : 's'}
			</p>
		</div>
	</section>

	<section class='pb-16 border-t border-border/70'>
		<div class='container mx-auto pt-10 grid gap-8 md:grid-cols-2'>
			{
				sortedPosts.map((post) => (
					<a
						href={`/blog/${post.slug}`}
						class='group bg-surface/70 rounded-2xl overflow-hidden border border-border/70 hover:border-accent/60 transition-all duration-300'
					>
						{post.data.image && (
							<div class='aspect-video overflow-hidden'>
								<img
									src={post.data.image}
									alt={post.data.title}
									class='w-full h-full object-cover group-hover:scale-105 transition-transform duration-300'
								/>
							</div>
						)}
						<div class='p-6'>
							<h3 class='text-lg font-semibold mb-2'>{post.data.title}</h3>
							<p class='text-sm text-muted mb-4 line-clamp-3'>
								{post.data.excerpt}
							</p>
							<span class='text-xs text-muted'>
								{new Date(post.data.publishDate).toLocaleDateString('en-US', {
									year: 'numeric',
									month: 'short',
									day: 'numeric',
								})}
							</span>
						</div>
					</a>
				))
			}
		</div>
	</section>
</Layout>
