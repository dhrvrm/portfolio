---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.slug },
		props: { project },
	}));
}

const { project } = Astro.props;

const schema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: project.data.title,
	description: project.data.description,
	image: project.data.image,
	datePublished: project.data.publishDate,
	author: {
		'@type': 'Person',
		name: 'Dhruv Verma',
	},
};
---

<Layout
	title={`${project.data.title} - Project by Dhruv Verma`}
	description={project.data.description}
>
	<div class='container mx-auto py-16'>
		<nav class='flex mb-8 text-sm text-muted' aria-label='Breadcrumb'>
			<ol class='flex items-center space-x-2'>
				<li>
					<a href='/' class='hover:text-ink'>Home</a>
				</li>
				<li class='text-gray-400'>/</li>
				<li>
					<a href='/projects' class='hover:text-ink'>Projects</a>
				</li>
				<li class='text-gray-400'>/</li>
				<li class='text-ink'>{project.data.title}</li>
			</ol>
		</nav>

		<article class='max-w-4xl mx-auto'>
			<header class='mb-12'>
				<h1 class='text-3xl md:text-5xl font-semibold font-display mb-4'>
					{project.data.title}
				</h1>
				<div class='flex flex-wrap gap-4 items-center text-sm text-muted'>
					<span>{project.data.category}</span>
					<span>•</span>
					<span>{project.data.duration}</span>
					<span>•</span>
					<span>{project.data.role}</span>
				</div>
			</header>

			<div
				class='aspect-video mb-12 rounded-2xl overflow-hidden border border-border/70 group'
			>
				<Image
					width={800}
					height={450}
					src={project.data.image}
					alt={project.data.title}
					loading='eager'
					class='w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000 ease-out'
				/>
			</div>

			<div class='grid md:grid-cols-3 gap-8 mb-12'>
				<div class='space-y-2'>
					<h2 class='font-semibold'>Challenge</h2>
					<p class='text-sm text-muted'>{project.data.challenge}</p>
				</div>
				<div class='space-y-2'>
					<h2 class='font-semibold'>Solution</h2>
					<p class='text-sm text-muted'>{project.data.solution}</p>
				</div>
				<div class='space-y-2'>
					<h2 class='font-semibold'>Impact</h2>
					<p class='text-sm text-muted'>{project.data.impact}</p>
				</div>
			</div>

			<div class='flex flex-wrap gap-4 mb-12'>
				{
					project.data.tech.map((tech) => (
						<span class='px-3 py-1 rounded-full text-xs border border-border/70 text-muted'>
							{tech}
						</span>
					))
				}
			</div>

			{
				(project.data.website || project.data.repository) && (
					<div class='flex gap-4 flex-wrap'>
						{project.data.website && (
							<a
								href={project.data.website}
								target='_blank'
								rel='noopener noreferrer'
								class='inline-flex items-center px-4 py-2 rounded-md bg-accent text-white hover:bg-accentStrong transition-colors'
								aria-label='Visit website (opens in new tab)'
							>
								Visit Website
							</a>
						)}
						{project.data.repository && (
							<a
								href={project.data.repository}
								target='_blank'
								rel='noopener noreferrer'
								class='inline-flex items-center px-4 py-2 rounded-md border border-border/70 text-ink hover:border-accent hover:text-accent transition-colors'
								aria-label='View code repository (opens in new tab)'
							>
								View Code
							</a>
						)}
					</div>
				)
			}
		</article>
	</div>
</Layout>

<script type='application/ld+json' set:html={JSON.stringify(schema)} />
