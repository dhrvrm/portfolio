---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';
import { AUTHOR } from '../../data/constants';

export async function getStaticPaths() {
	const projects = (await getCollection('projects')).sort(
		(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
	);
	return projects.map((project, i) => ({
		params: { slug: project.slug },
		props: {
			project,
			prev: projects[i - 1] ?? null, // newer
			next: projects[i + 1] ?? null, // older
		},
	}));
}

const { project, prev, next } = Astro.props;
const site = Astro.site?.toString() ?? 'https://dhruvverma.dev';

const categoryLabel =
	project.data.category === 'client' ? 'Client work' : 'Personal project';
const year = project.data.publishDate.getFullYear();

const facts = [
	{ label: 'Role', value: project.data.role },
	{ label: 'Timeline', value: project.data.duration },
	project.data.client ? { label: 'Client', value: project.data.client } : null,
	{ label: 'Type', value: categoryLabel },
	{ label: 'Year', value: String(year) },
].filter(Boolean) as { label: string; value: string }[];

const story = [
	{ label: 'Challenge', body: project.data.challenge },
	{ label: 'Solution', body: project.data.solution },
	{ label: 'Impact', body: project.data.impact },
];

const schema = {
	'@context': 'https://schema.org',
	'@type': 'CreativeWork',
	name: project.data.title,
	description: project.data.description,
	url: new URL(`/projects/${project.slug}`, site).toString(),
	image: new URL(project.data.image, site).toString(),
	datePublished: project.data.publishDate,
	keywords: project.data.tech.join(', '),
	...(project.data.website || project.data.repository
		? {
				sameAs: [project.data.website, project.data.repository].filter(Boolean),
			}
		: {}),
	author: {
		'@type': 'Person',
		name: AUTHOR.name,
		url: site,
		sameAs: Object.values(AUTHOR.social),
	},
};
---

<Layout
	title={`${project.data.title} - Project by Dhruv Verma`}
	description={project.data.description}
	image={project.data.image}
>
	<div class='container mx-auto py-16'>
		<Breadcrumbs
			items={[
				{ label: 'Home', href: '/' },
				{ label: 'Projects', href: '/projects' },
				{ label: project.data.title },
			]}
		/>

		<article>
			<header class='mb-10'>
				<h1
					class='text-3xl md:text-5xl font-semibold font-display tracking-tight text-balance'
				>
					{project.data.title}
				</h1>
				<p class='mt-5 text-lg md:text-xl text-muted leading-relaxed text-pretty max-w-[55ch]'>
					{project.data.description}
				</p>
			</header>

			<div
				class='aspect-video mb-14 rounded-2xl overflow-hidden border border-border/70 group'
			>
				<Image
					width={1000}
					height={563}
					src={project.data.image}
					alt={`${project.data.title}, ${categoryLabel.toLowerCase()} by ${AUTHOR.name}`}
					loading='eager'
					class='w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03] motion-reduce:transition-none motion-reduce:group-hover:scale-100'
				/>
			</div>

			<div class='grid lg:grid-cols-[260px_1fr] gap-10 lg:gap-16'>
				<!-- Fact sheet: sticky on desktop, leads on mobile so the CTAs sit near the top -->
				<aside class='lg:sticky lg:top-28 self-start space-y-8'>
					<dl class='grid grid-cols-2 lg:grid-cols-1 gap-x-6 gap-y-5'>
						{
							facts.map((fact) => (
								<div>
									<dt class='font-mono text-[0.7rem] uppercase tracking-[0.12em] text-muted'>
										{fact.label}
									</dt>
									<dd class='mt-1 text-sm font-medium text-ink'>{fact.value}</dd>
								</div>
							))
						}
					</dl>

					<div class='border-t border-border/60 pt-6'>
						<h2 class='font-mono text-[0.7rem] uppercase tracking-[0.12em] text-muted'>
							Stack
						</h2>
						<div class='mt-3 flex flex-wrap gap-2'>
							{
								project.data.tech.map((tech) => (
									<span class='px-3 py-1 rounded-full text-xs border border-border/70 text-muted'>
										{tech}
									</span>
								))
							}
						</div>
					</div>

					{
						(project.data.website || project.data.repository) && (
							<div class='flex flex-col gap-3 border-t border-border/60 pt-6'>
								{project.data.website && (
									<a
										href={project.data.website}
										target='_blank'
										rel='noopener noreferrer'
										class='inline-flex items-center justify-center px-4 py-2.5 rounded-md bg-accent text-onAccent text-sm font-semibold hover:bg-accentStrong transition-colors active:scale-[0.98]'
										aria-label='Visit the live website (opens in new tab)'
									>
										Visit live site
									</a>
								)}
								{project.data.repository && (
									<a
										href={project.data.repository}
										target='_blank'
										rel='noopener noreferrer'
										class='inline-flex items-center justify-center px-4 py-2.5 rounded-md border border-border text-sm font-semibold text-ink hover:border-accent hover:text-accent transition-colors active:scale-[0.98]'
										aria-label='View the code repository (opens in new tab)'
									>
										View code
									</a>
								)}
							</div>
						)
					}
				</aside>

				<!-- Narrative: the case study reads as a sequence, not three tiny equal columns -->
				<div class='min-w-0'>
					{
						story.map((part) => (
							<section class='py-8 border-t border-border/60 first:border-t-0 first:pt-0'>
								<h2 class='font-mono text-xs uppercase tracking-[0.15em] text-accent'>
									{part.label}
								</h2>
								<p class='mt-4 text-base md:text-lg leading-relaxed text-muted text-pretty max-w-[62ch]'>
									{part.body}
								</p>
							</section>
						))
					}
				</div>
			</div>

			{
				(prev || next) && (
					<nav
						class='mt-16 pt-8 border-t border-border/60 grid sm:grid-cols-2 gap-6'
						aria-label='More projects'
					>
						{prev ? (
							<a
								href={`/projects/${prev.slug}`}
								class='group rounded-xl border border-border/70 bg-surface/70 p-5 hover:border-accent/60 transition-colors'
							>
								<span class='font-mono text-[0.7rem] uppercase tracking-[0.12em] text-muted'>
									&larr; Newer project
								</span>
								<p class='mt-1.5 font-semibold font-display group-hover:text-accent transition-colors'>
									{prev.data.title}
								</p>
							</a>
						) : (
							<span />
						)}
						{next ? (
							<a
								href={`/projects/${next.slug}`}
								class='group rounded-xl border border-border/70 bg-surface/70 p-5 hover:border-accent/60 transition-colors sm:text-right'
							>
								<span class='font-mono text-[0.7rem] uppercase tracking-[0.12em] text-muted'>
									Older project &rarr;
								</span>
								<p class='mt-1.5 font-semibold font-display group-hover:text-accent transition-colors'>
									{next.data.title}
								</p>
							</a>
						) : (
							<span />
						)}
					</nav>
				)
			}
		</article>
	</div>
</Layout>

<script type='application/ld+json' set:html={JSON.stringify(schema)} />
