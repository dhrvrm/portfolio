---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');

// Sort projects: featured first, then by publish date (newest first)
const sortedProjects = projects.sort((a, b) => {
	// First sort by featured status
	if (a.data.featured && !b.data.featured) return -1;
	if (!a.data.featured && b.data.featured) return 1;

	// Then sort by publish date (newest first)
	return (
		new Date(b.data.publishDate).getTime() -
		new Date(a.data.publishDate).getTime()
	);
});

const schema = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: 'Projects - Dhruv Verma',
	description:
		'Portfolio of web development and design projects by Dhruv Verma',
	author: {
		'@type': 'Person',
		name: 'Dhruv Verma',
	},
	mainEntity: {
		'@type': 'ItemList',
		itemListElement: sortedProjects.map((project, index) => ({
			'@type': 'ListItem',
			position: index + 1,
			item: {
				'@type': 'WebPage',
				name: project.data.title,
				description: project.data.description,
				url: `https://dhruvverma.dev/projects/${project.slug}`,
			},
		})),
	},
};
---

<Layout
	title='Projects - Dhruv Verma | Frontend Developer Portfolio'
	description='Explore my portfolio of web development projects, including React applications, e-commerce platforms, and B2B solutions.'
>
	<div class='container mx-auto py-16'>
		<p class='font-mono text-sm uppercase tracking-[0.12em] text-muted'>Work</p>
		<h1 class='text-3xl md:text-5xl font-semibold font-display mt-4 mb-4'>
			Selected projects
		</h1>
		<p class='text-muted mb-12 max-w-2xl'>
			A collection of my work, including client projects and personal
			experiments.
		</p>

		<div class='grid gap-8 md:grid-cols-2 lg:grid-cols-3'>
			{
				sortedProjects.length > 0 ? (
					sortedProjects.map((project) => (
						<a
							href={`/projects/${project.slug}`}
							class='group relative bg-surface/70 rounded-2xl overflow-hidden border border-border/70 hover:border-accent/60 transition-all duration-300'
						>
							<div class='relative aspect-video overflow-hidden'>
								<Image
									width={390}
									height={220}
									src={project.data.image}
									alt={project.data.title}
									class='w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out'
								/>
								<div class='absolute inset-0 bg-gradient-to-t from-black/45 to-transparent opacity-0 group-hover:opacity-100 transition-opacity' />
							</div>

							<div class='p-6'>
								<h2 class='text-xl font-semibold mb-2 group-hover:text-ink transition-colors'>
									{project.data.title}
								</h2>

								<p class='text-muted mb-4 line-clamp-2'>
									{project.data.description}
								</p>

								<div class='flex flex-wrap gap-2'>
									{project.data.tech.slice(0, 3).map((tech) => (
										<span class='px-3 py-1 rounded-full text-xs border border-border/70 text-muted'>
											{tech}
										</span>
									))}
									{project.data.tech.length > 3 && (
										<span class='px-3 py-1 rounded-full text-xs border border-border/70 text-muted'>
											+{project.data.tech.length - 3} more
										</span>
									)}
								</div>
							</div>
						</a>
					))
				) : (
					<div class='col-span-full text-center py-12'>
						<p class='text-muted'>No projects found.</p>
					</div>
				)
			}
		</div>
	</div>
</Layout>

<script type='application/ld+json' set:html={JSON.stringify(schema)} />
