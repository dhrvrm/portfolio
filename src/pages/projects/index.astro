---
import Layout from '../../layouts/Layout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { AUTHOR } from '../../data/constants';
import { featuredThenNewest } from '../../utils/content';

const projects = await getCollection('projects');
const site = Astro.site?.toString() ?? 'https://dhruvverma.dev';

// Featured first, then newest first.
const sortedProjects = projects.sort(
	featuredThenNewest(
		(p) => p.data.featured,
		(p) => p.data.publishDate,
	),
);

// Mixed rhythm: one big feature, then repeating [trio, asymmetric duo].
// A trailing single becomes another big feature so no row is ever orphaned.
const [feature, ...others] = sortedProjects;
const cycle = [3, 2];
type Row =
	| { type: 'trio'; items: typeof others }
	| { type: 'duo'; items: typeof others; flip: boolean }
	| { type: 'feature'; items: typeof others };
const rows: Row[] = [];
let i = 0;
let step = 0;
let duoCount = 0;
while (i < others.length) {
	const size = cycle[step % cycle.length];
	const items = others.slice(i, i + size);
	if (items.length === 1) {
		rows.push({ type: 'feature', items });
	} else if (items.length === 2) {
		rows.push({ type: 'duo', items, flip: duoCount % 2 === 1 });
		duoCount++;
	} else {
		rows.push({ type: 'trio', items });
	}
	i += size;
	step++;
}

const schema = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: 'Projects - Dhruv Verma',
	description:
		'Portfolio of web development and design projects by Dhruv Verma',
	author: {
		'@type': 'Person',
		name: AUTHOR.name,
		url: site,
		sameAs: Object.values(AUTHOR.social),
	},
	mainEntity: {
		'@type': 'ItemList',
		itemListElement: sortedProjects.map((project, index) => ({
			'@type': 'ListItem',
			position: index + 1,
			item: {
				'@type': 'WebPage',
				name: project.data.title,
				description: project.data.description,
				url: new URL(`/projects/${project.slug}`, site).toString(),
				image: new URL(project.data.image, site).toString(),
			},
		})),
	},
};
---

<Layout
	title='Projects - Dhruv Verma | Frontend Developer Portfolio'
	description='Explore my portfolio of web development projects, including React applications, e-commerce platforms, and B2B solutions.'
>
	<div class='container mx-auto py-16'>
		<h1
			class='text-3xl md:text-5xl font-semibold font-display tracking-tight text-balance'
		>
			Selected projects
		</h1>
		<p class='text-lg text-muted mt-4 mb-12 max-w-2xl text-pretty'>
			A collection of my work, across client engagements and personal
			experiments.
		</p>

		{
			sortedProjects.length === 0 ? (
				<p class='text-muted'>No projects yet. Check back soon.</p>
			) : (
				<div class='space-y-8'>
					{feature && <ProjectCard project={feature} feature eager />}

					{rows.map((row) =>
						row.type === 'trio' ? (
							<div class='row-trio'>
								{row.items.map((p) => (
									<ProjectCard project={p} />
								))}
							</div>
						) : row.type === 'duo' ? (
							<div class:list={['row-duo', { 'row-duo--flip': row.flip }]}>
								{row.items.map((p) => (
									<ProjectCard project={p} />
								))}
							</div>
						) : (
							row.items.map((p) => <ProjectCard project={p} feature />)
						),
					)}
				</div>
			)
		}
	</div>
</Layout>

<script type='application/ld+json' set:html={JSON.stringify(schema)} />

<style>
	/* Trio: three equal columns (2 on tablet, 1 on mobile) */
	.row-trio {
		display: grid;
		gap: 2rem;
		grid-template-columns: 1fr;
	}
	@media (min-width: 640px) {
		.row-trio {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (min-width: 1024px) {
		.row-trio {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	/* Asymmetric duo: unequal columns on desktop, flipping wide side each time */
	.row-duo {
		display: grid;
		gap: 2rem;
		grid-template-columns: 1fr;
	}
	@media (min-width: 768px) {
		.row-duo {
			grid-template-columns: 1.6fr 1fr;
		}
		.row-duo--flip {
			grid-template-columns: 1fr 1.6fr;
		}
	}
</style>
