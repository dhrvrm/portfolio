---
import Layout from '../../layouts/Layout.astro';
import ActivitySection from '../../components/ActivitySection.astro';
import PinnedScrollGallery from '../../components/PinnedScrollGallery.astro';
import { getCollection } from 'astro:content';

const items = await getCollection('activities');

const byDateDesc = (a: (typeof items)[0], b: (typeof items)[0]) =>
	b.data.date.getTime() - a.data.date.getTime();

// Static section images (not derived from latest activity)
const EVENTS_SECTION_IMAGE = '/images/activities/gittogether-meetup-aug-2024/gittogether-aug-24-1.webp';
const HACKATHONS_SECTION_IMAGE = '/images/activities/srm-builds-6/srm-1.webp';

const getCategoryImage = (slug: string) => {
	if (slug === 'events') return EVENTS_SECTION_IMAGE;
	if (slug === 'hackathons') return HACKATHONS_SECTION_IMAGE;
	if (slug === 'speaking') return EVENTS_SECTION_IMAGE;
	const list = items.filter((i) => i.data.category === slug).sort(byDateDesc);
	const first = list[0];
	const imgs = first?.data.images ?? [];
	return imgs[0] ?? null;
};

// Category-specific images for galleries
const awardsImages = items
	.filter((i) => i.data.category === 'awards')
	.flatMap((i) => i.data.images ?? []);

const travelImages = items
	.filter((i) => i.data.category === 'travel')
	.flatMap((i) => i.data.images ?? []);

// Pool of all activity images (exclude placeholders) for filling galleries
const rawPool = items.flatMap((i) => i.data.images ?? []);
const pool = [...new Set(rawPool.filter((src) => !src.toLowerCase().includes('placeholder')))];

// Deterministic shuffle so each gallery gets a varied mix when filled
const hash = (s: string) => {
	let h = 0;
	for (let i = 0; i < s.length; i++) h = ((h << 5) - h + s.charCodeAt(i)) | 0;
	return h;
};
const shuffledPool = [...pool].sort((a, b) => hash(a) - hash(b));

const MIN_GALLERY = 8;
const fillGallery = (categoryImages: string[]) => {
	const base = categoryImages.length ? categoryImages : shuffledPool.slice(0, MIN_GALLERY);
	if (base.length >= MIN_GALLERY) return base;
	const used = new Set(base);
	const extra = shuffledPool.filter((src) => !used.has(src));
	const need = MIN_GALLERY - base.length;
	return [...base, ...extra.slice(0, need)];
};

const recognitionGalleryImages = fillGallery(awardsImages);
const travelGalleryImages = fillGallery(travelImages);
---

<Layout title='Activities - Dhruv Verma'>
	<!-- Hero: overview only, no nav, no numbers -->
	<section class='act-hero'>
		<div class='act-hero__inner'>
			<p class='act-hero__eyebrow'>Activities</p>
			<h1 class='act-hero__title'>Events, mentoring &amp; beyond</h1>
			<p class='act-hero__desc'>
				A snapshot of events I've covered, hackathons I've volunteered at as a mentor, talks I've
				given, recognition received, and places I've traveled for the craft.
			</p>
		</div>
	</section>

	<!-- 3 alternating text + image sections -->
	<ActivitySection
		title='Events covered'
		description="Conferences, meetups, and community events I've attended and covered. Story-led highlights and takeaways shared with the community."
		href='/activities/events'
		align='left'
		image={getCategoryImage('events')}
	/>
	<ActivitySection
		title='Hackathons'
		description='Volunteer mentoring, judging, and participating in hackathons. Helping teams with frontend strategy, product storytelling, and rapid prototyping.'
		href='/activities/hackathons'
		align='right'
		image={getCategoryImage('hackathons')}
	/>
	<ActivitySection
		title='Speaking'
		description='Talks, workshops, and panel discussions on design systems, scalable frontend architecture, and motion in product design.'
		href='/activities/speaking'
		align='left'
		image={getCategoryImage('speaking')}
	/>

	<!-- Pinned scroll galleries: Recognition, Travel -->
	<PinnedScrollGallery
		id='recognition-gallery'
		title='Recognition'
		href='/activities/awards'
		images={recognitionGalleryImages.length ? recognitionGalleryImages : [EVENTS_SECTION_IMAGE]}
	/>
	<PinnedScrollGallery
		id='travel-gallery'
		title='Travel'
		href='/activities/travel'
		images={travelGalleryImages.length ? travelGalleryImages : [EVENTS_SECTION_IMAGE]}
	/>
</Layout>

<style>
	.act-hero {
		padding: 4rem 0 5rem;
		border-bottom: 1px solid rgb(var(--color-border) / 0.5);
	}

	.act-hero__inner {
		max-width: 42rem;
		margin: 0;
		padding: 0 1.5rem;
	}

	.act-hero__eyebrow {
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.25em;
		color: rgb(var(--color-muted));
		margin: 0 0 0.75rem;
	}

	.act-hero__title {
		font-family:
			'Space Grotesk Variable', 'Inter Variable', system-ui, sans-serif;
		font-size: clamp(2rem, 5vw, 3rem);
		font-weight: 600;
		letter-spacing: -0.02em;
		line-height: 1.2;
		margin: 0 0 1rem;
	}

	.act-hero__desc {
		font-size: 1.1rem;
		line-height: 1.6;
		color: rgb(var(--color-muted));
		margin: 0;
	}
</style>
