---
import ActivityLayout from '../../layouts/ActivityLayout.astro';
import ActivityCard from '../../components/ActivityCard.astro';
import { getCollection } from 'astro:content';

const items = await getCollection('activities');
const events = items
	.filter((i) => i.data.category === 'events')
	.sort((a, b) => {
		if (b.data.featured !== a.data.featured)
			return Number(b.data.featured) - Number(a.data.featured);
		return b.data.date.getTime() - a.data.date.getTime();
	});

const groupByYear = (list: typeof events) => {
	const groups = list.reduce(
		(acc, item) => {
			const year = String(item.data.date.getFullYear());
			if (!acc[year]) acc[year] = [];
			acc[year].push(item);
			return acc;
		},
		{} as Record<string, typeof events>,
	);
	return Object.entries(groups).sort(([a], [b]) => Number(b) - Number(a));
};
---

<ActivityLayout title='Events - Dhruv Verma' current='events'>
	<h1 class='text-2xl md:text-3xl font-semibold font-display mb-2'>
		Events covered
	</h1>
	<p class='text-muted mb-8'>
		Conferences, meetups, and community events I have covered.
	</p>

	{events.length ? (
			<div class='space-y-10'>
				{groupByYear(events).map(([year, entries]) => (
					<div id={`year-${year}`} class='scroll-mt-24'>
						<p class='font-mono text-xs uppercase tracking-[0.12em] text-muted mb-4'>
							{year}
						</p>
						<div class='grid md:grid-cols-2 gap-6'>
							{entries.map((item) => (
								<ActivityCard
									item={item}
									showNarrative={true}
									variant='asymmetric'
								/>
							))}
						</div>
					</div>
				))}
			</div>
	) : (
		<p class='text-sm text-muted'>No events listed yet.</p>
	)}
</ActivityLayout>
