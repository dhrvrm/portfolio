---
import ActivityLayout from '../../layouts/ActivityLayout.astro';
import ActivityCard from '../../components/ActivityCard.astro';
import { getCollection } from 'astro:content';

const items = await getCollection('activities');
const hackathons = items
	.filter((i) => i.data.category === 'hackathons')
	.sort((a, b) => {
		if (b.data.featured !== a.data.featured)
			return Number(b.data.featured) - Number(a.data.featured);
		return b.data.date.getTime() - a.data.date.getTime();
	});

const groupByYear = (list: typeof hackathons) => {
	const groups = list.reduce(
		(acc, item) => {
			const year = String(item.data.date.getFullYear());
			if (!acc[year]) acc[year] = [];
			acc[year].push(item);
			return acc;
		},
		{} as Record<string, typeof hackathons>,
	);
	return Object.entries(groups).sort(([a], [b]) => Number(b) - Number(a));
};

const byType = (type: string) =>
	hackathons.filter((i) => i.data.hackathonType === type);
const other = hackathons.filter(
	(i) =>
		!['participated', 'mentored', 'judged'].includes(
			i.data.hackathonType ?? '',
		),
);
const sections = [
	{ label: 'Participated', items: byType('participated') },
	{ label: 'Mentored', items: byType('mentored') },
	{ label: 'Judged', items: byType('judged') },
	{ label: 'Other', items: other },
].filter((s) => s.items.length > 0);
---

<ActivityLayout title='Hackathons - Dhruv Verma' current='hackathons'>
	<h1 class='text-2xl md:text-3xl font-semibold font-display mb-2'>
		Hackathons
	</h1>
	<p class='text-muted mb-8'>
		Hackathons I have participated in, mentored, or judged.
	</p>

	{
		hackathons.length ? (
			<div class='space-y-12'>
				{sections.map((section) => (
					<div>
						<h2 class='text-lg font-medium text-muted mb-4'>{section.label}</h2>
						<div class='space-y-8'>
							{groupByYear(section.items).map(([year, entries]) => (
								<div>
									<p class='font-mono text-xs uppercase tracking-[0.12em] text-muted mb-4'>
										{year}
									</p>
									<div class='grid md:grid-cols-2 gap-6'>
										{entries.map((item) => (
											<ActivityCard item={item} />
										))}
									</div>
								</div>
							))}
						</div>
					</div>
				))}
			</div>
		) : (
			<p class='text-sm text-muted'>No hackathons listed yet.</p>
		)
	}
</ActivityLayout>
