---
import ActivityLayout from '../../layouts/ActivityLayout.astro';
import ActivityCard from '../../components/ActivityCard.astro';
import { getActivities, inCategory } from '../../utils/activities';
import { groupByYear } from '../../utils/content';

const hackathons = inCategory(await getActivities(), 'hackathons');

const byType = (type: string) =>
	hackathons.filter((i) => i.data.hackathonType === type);
const other = hackathons.filter(
	(i) =>
		!['participated', 'mentored', 'judged'].includes(
			i.data.hackathonType ?? '',
		),
);
const sections = [
	{ label: 'Participated', items: byType('participated') },
	{ label: 'Coached', items: byType('mentored') },
	{ label: 'Judged', items: byType('judged') },
	{ label: 'Other', items: other },
].filter((s) => s.items.length > 0);
---

<ActivityLayout title='Hackathons - Dhruv Verma' current='hackathons'>
	<h1 class='text-2xl md:text-3xl font-semibold font-display mb-2'>
		Hackathons
	</h1>
	<p class='text-muted mb-8'>
		Hackathons I've participated in, coached at, or judged.
	</p>

	{
		hackathons.length ? (
			<div class='space-y-12'>
				{sections.map((section) => (
					<div>
						<h2 class='text-lg font-medium text-muted mb-4'>{section.label}</h2>
						<div class='space-y-8'>
							{groupByYear(section.items, (i) => i.data.date).map(([year, entries]) => (
								<div>
									<p class='font-mono text-xs uppercase tracking-[0.12em] text-muted mb-4'>
										{year}
									</p>
									<div class='grid md:grid-cols-2 gap-6'>
										{entries.map((item) => (
											<ActivityCard item={item} />
										))}
									</div>
								</div>
							))}
						</div>
					</div>
				))}
			</div>
		) : (
			<p class='text-sm text-muted'>No hackathons listed yet.</p>
		)
	}
</ActivityLayout>
