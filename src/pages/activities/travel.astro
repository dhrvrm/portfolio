---
import ActivityLayout from '../../layouts/ActivityLayout.astro';
import ActivityCard from '../../components/ActivityCard.astro';
import { getActivities, inCategory } from '../../utils/activities';
import { groupByYear } from '../../utils/content';

const travel = inCategory(await getActivities(), 'travel');
---

<ActivityLayout title='Travel - Dhruv Verma' current='travel'>
	<h1 class='text-2xl md:text-3xl font-semibold font-display mb-2'>Travel</h1>
	<p class='text-muted mb-8'>
		Places visited for work, conferences, and exploration.
	</p>

	{
		travel.length ? (
			<div class='space-y-10'>
				{groupByYear(travel, (i) => i.data.date).map(([year, entries]) => (
					<div>
						<p class='font-mono text-xs uppercase tracking-[0.12em] text-muted mb-4'>
							{year}
						</p>
						<div class='grid md:grid-cols-2 gap-6'>
							{entries.map((item) => (
								<ActivityCard
									item={item}
									showNarrative={true}
									variant='asymmetric'
								/>
							))}
						</div>
					</div>
				))}
			</div>
		) : (
			<p class='text-sm text-muted'>No travel entries yet.</p>
		)
	}
</ActivityLayout>
