	.travel-polaroids__rain-cell:nth-of-type(1) { --duration: 2.7s; --delay: 1s; transform: translate(10%, 10%) scale(0.9); }
	.travel-polaroids__rain-cell:nth-of-type(2) { --duration: 2.1s; --delay: 1.2s; transform: translate(-20%, 40%) scale(1.3); }
	.travel-polaroids__rain-cell:nth-of-type(3) { --duration: 2.3s; --delay: 2s; transform: translate(0%, 50%) scale(1.1); }
	.travel-polaroids__rain-cell:nth-of-type(4) { --duration: 2s; --delay: 4s; transform: translate(0%, -10%) scale(1.2); }
	.travel-polaroids__rain-cell:nth-of-type(5) { --duration: 2.5s; --delay: 0s; transform: translate(10%, 0%) scale(0.9); }
	.travel-polaroids__rain-cell:nth-of-type(6) { --duration: 2s; --delay: 2.7s; transform: translate(-20%, 0%) scale(1); }
	.travel-polaroids__rain-cell:nth-of-type(7) { --duration: 1.8s; --delay: 1.3s; transform: translate(20%, -40%) scale(1.2); }
	.travel-polaroids__rain-cell:nth-of-type(8) { --duration: 2.2s; --delay: 0s; transform: translate(20%, 0%) scale(1); }
	.travel-polaroids__rain-cell:nth-of-type(9) { --duration: 2s; --delay: 0.5s; transform: translate(0%, -10%) scale(1.3); }
	.travel-polaroids__rain .drop {
		background-color: rgb(var(--color-ink) / 0.35);
		width: 3px;
		height: 100px;
		position: absolute;
		top: calc(50% - 100px);
		left: calc(50% - 1.5px);
		animation-name: travel-rain-fall;
		animation-duration: var(--duration);
		animation-delay: var(--delay);
		animation-iteration-count: infinite;
		animation-timing-function: ease-in;
		animation-fill-mode: backwards;
	}
	@keyframes travel-rain-fall {
		0% { transform: translateY(-120vh); }
		45% { transform: translateY(0%); opacity: 1; }
		46% { opacity: 0; }
		100% { opacity: 0; }
	}
	.travel-polaroids__rain .waves > div {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		border-radius: 50%;
		border: solid rgb(var(--color-ink) / 0.25) 3px;
		animation-name: travel-rain-spread;
		animation-duration: var(--duration);
		animation-delay: var(--delay);
		animation-iteration-count: infinite;
		animation-timing-function: ease-out;
		animation-fill-mode: backwards;
	}
