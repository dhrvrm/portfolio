---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CursorFollower from '../components/CursorFollower.astro';
import TransitionOverlay from '../components/TransitionOverlay.astro';
import '@fontsource-variable/inter';
import '@fontsource-variable/space-grotesk';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '../styles/base.css';
import '../styles/tokens.css';

interface Props {
	title: string;
	description?: string;
	image?: string;
	imageWidth?: number;
	imageHeight?: number;
	article?: boolean;
	prevHref?: string;
	nextHref?: string;
}

const {
	title,
	description = 'Software engineer building reliable products, mentoring builders, and learning through travel and collaboration.',
	image = '/og-image.png',
	imageWidth,
	imageHeight,
	article = false,
	prevHref,
	nextHref,
} = Astro.props;

const canonicalURL = new URL(
	Astro.url.pathname,
	Astro.site || 'https://dhruvverma.dev',
).toString();
---

<!doctype html>
<html lang='en' class='scroll-smooth'>
	<head>
		<meta charset='UTF-8' />
		<meta name='description' content={description} />
		<meta name='viewport' content='width=device-width' />
		<script is:inline>
			(() => {
				try {
					const stored = localStorage.getItem('theme');
					const prefersDark = window.matchMedia(
						'(prefers-color-scheme: dark)',
					).matches;
					const theme = stored || (prefersDark ? 'dark' : 'light');
					if (theme === 'dark') {
						document.documentElement.classList.add('dark');
					} else {
						document.documentElement.classList.remove('dark');
					}
				} catch (error) {
					console.warn('Theme init failed', error);
				}
			})();
		</script>

		<link rel='icon' type='image/png' href='/favicon-96x96.png' sizes='96x96' />
		<link rel='icon' type='image/svg+xml' href='/favicon.svg' />
		<link rel='shortcut icon' href='/favicon.ico' />
		<link rel='apple-touch-icon' sizes='180x180' href='/apple-touch-icon.png' />
		<meta name='apple-mobile-web-app-title' content='Dhruv' />
		<link rel='manifest' href='/site.webmanifest' />

		<meta name='generator' content={Astro.generator} />
		<link rel='canonical' href={canonicalURL} />
		{prevHref && (
			<link rel='prev' href={new URL(prevHref, Astro.site).toString()} />
		)}
		{nextHref && (
			<link rel='next' href={new URL(nextHref, Astro.site).toString()} />
		)}
		<title>{title}</title>
		<style is:global>
			/* Critical: overlay covers from first paint so no flash before entrance */
			#page-transition {
				position: fixed;
				inset: 0;
				z-index: 9999;
				overflow: hidden;
				pointer-events: none;
			}
			#page-transition .pt__panel {
				position: absolute;
				top: 0;
				bottom: 0;
				width: 50vw;
				background: rgb(var(--color-surface));
			}
			#page-transition .pt__panel--left {
				left: 0;
				transform: translateX(0);
			}
			#page-transition .pt__panel--right {
				right: 0;
				transform: translateX(0);
			}
			#page-transition .pt__circle {
				position: absolute;
				left: 50%;
				top: 50%;
				width: 8rem;
				height: 8rem;
				margin: -4rem 0 0 -4rem;
				border-radius: 50%;
				background: rgb(var(--color-accent) / 0.25);
				filter: blur(40px);
				transform: scale(8);
				opacity: 0.9;
			}
		</style>
		<style is:global>
			html {
				scroll-padding-top: 100px;
			}

			/* Custom Scrollbar - Global */
			::-webkit-scrollbar {
				width: 10px;
				height: 10px;
			}

			::-webkit-scrollbar-track {
				background: transparent;
			}

			/* Light theme scrollbar */
			::-webkit-scrollbar-thumb {
				background-color: rgba(156, 163, 175, 0.5);
				border-radius: 9999px;
				border: 2px solid transparent;
				background-clip: content-box;
			}

			::-webkit-scrollbar-thumb:hover {
				background-color: rgba(156, 163, 175, 0.7);
			}

			/* Dark theme scrollbar */
			:root.dark ::-webkit-scrollbar-thumb {
				background-color: rgba(75, 85, 99, 0.5);
			}

			:root.dark ::-webkit-scrollbar-thumb:hover {
				background-color: rgba(75, 85, 99, 0.7);
			}

			/* For Firefox */
			* {
				scrollbar-width: thin;
				scrollbar-color: rgba(156, 163, 175, 0.5) transparent;
			}

			:root.dark * {
				scrollbar-color: rgba(75, 85, 99, 0.5) transparent;
			}
		</style>
		<script>
			// Enhanced clipboard functionality for all code blocks
			function addClipboardToCodeBlocks() {
				// Target both pre tags and code blocks with specific classes
				const codeBlocks = document.querySelectorAll(
					'pre, .astro-code, .shiki, [class*="language-"]',
				);

				codeBlocks.forEach((block) => {
					// Skip if already has clipboard button
					if (block.querySelector('.clipboard-button')) return;

					const wrapper = document.createElement('div');
					wrapper.className = 'relative group';

					const button = document.createElement('button');
					button.className =
						'clipboard-button absolute top-2 right-2 p-2 rounded-md bg-gray-800/60 opacity-0 group-hover:opacity-100 transition-opacity text-gray-300 hover:text-white z-10';
					button.setAttribute('aria-label', 'Copy code to clipboard');
					button.innerHTML = `
						<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
							<path d="M8 3a1 1 0 011-1h2a1 1 0 110 2H9a1 1 0 01-1-1z" />
							<path d="M6 3a2 2 0 00-2 2v11a2 2 0 002 2h8a2 2 0 002-2V5a2 2 0 00-2-2 3 3 0 01-3 3H9a3 3 0 01-3-3z" />
						</svg>
					`;

					button.addEventListener('click', async (e) => {
						e.preventDefault();
						e.stopPropagation();

						try {
							// Get the text content, handling different code block structures
							let textToCopy = '';
							const codeElement = block.querySelector('code');

							if (codeElement) {
								textToCopy = codeElement.textContent || '';
							} else {
								textToCopy = block.textContent || '';
							}

							await navigator.clipboard.writeText(textToCopy);

							// Show success state
							button.innerHTML = `
								<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
									<path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z" />
									<path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm9.707 5.707a1 1 0 00-1.414-1.414L9 12.586l-1.293-1.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
								</svg>
							`;

							// Reset after 2 seconds
							setTimeout(() => {
								button.innerHTML = `
									<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
										<path d="M8 3a1 1 0 011-1h2a1 1 0 110 2H9a1 1 0 01-1-1z" />
										<path d="M6 3a2 2 0 00-2 2v11a2 2 0 002 2h8a2 2 0 002-2V5a2 2 0 00-2-2 3 3 0 01-3 3H9a3 3 0 01-3-3z" />
									</svg>
								`;
							}, 2000);
						} catch (err) {
							console.error('Failed to copy code:', err);
							// Fallback for older browsers
							const textArea = document.createElement('textarea');
							textArea.value = block.textContent || '';
							document.body.appendChild(textArea);
							textArea.select();
							document.execCommand('copy');
							document.body.removeChild(textArea);
						}
					});

					// Insert wrapper and move block into it
					if (block.parentNode) {
						block.parentNode.insertBefore(wrapper, block);
						wrapper.appendChild(block);
						wrapper.appendChild(button);
					}
				});
			}

			document.addEventListener('DOMContentLoaded', addClipboardToCodeBlocks);
		</script>
		<!-- Primary Meta Tags -->
		<meta name='title' content={title} />

		<!-- Open Graph / Facebook -->
		<meta property='og:type' content={article ? 'article' : 'website'} />
		<meta property='og:url' content={canonicalURL} />
		<meta property='og:title' content={title} />
		<meta property='og:description' content={description} />
		<meta property='og:image' content={new URL(image, Astro.site)} />
		{(imageWidth != null || image === '/og-image.png') && (
			<meta
				property='og:image:width'
				content={String(imageWidth ?? 1200)}
			/>
		)}
		{(imageHeight != null || image === '/og-image.png') && (
			<meta
				property='og:image:height'
				content={String(imageHeight ?? 630)}
			/>
		)}

		<!-- Twitter -->
		<meta property='twitter:card' content='summary_large_image' />
		<meta property='twitter:creator' content='@verma1300' />
		<meta property='twitter:url' content={canonicalURL} />
		<meta property='twitter:title' content={title} />
		<meta property='twitter:description' content={description} />
		<meta property='twitter:image' content={new URL(image, Astro.site)} />

		<!-- Google tag (gtag.js) -->
		<script
			type='text/partytown'
			async
			src='https://www.googletagmanager.com/gtag/js?id=G-3VCWW3H8PM'></script>
		<script type='text/partytown'>
			window.dataLayer = window.dataLayer || [];
			function gtag() {
				dataLayer.push(arguments);
			}
			gtag('js', new Date());

			gtag('config', 'G-3VCWW3H8PM');
		</script>
	</head>
	<body class='min-h-screen font-sans antialiased'>
		<script>
			import { gsap } from 'gsap';
			import { ScrollTrigger } from 'gsap/ScrollTrigger';
			gsap.registerPlugin(ScrollTrigger);
			window.gsap = gsap;
			window.ScrollTrigger = ScrollTrigger;
		</script>
		<a
			href='#main-content'
			class='skip-link sr-only bg-surface text-ink border border-border px-4 py-2 rounded-md shadow-lg'
		>
			Skip to content
		</a>
		<div
			class="fixed inset-0 bg-[url('/noise.png')] opacity-[0.02] pointer-events-none"
		>
		</div>
		<CursorFollower />
		<TransitionOverlay />
		<div class='max-w-7xl mx-auto px-6'>
			<Header />
			<main id='main-content' class='min-h-screen pt-24'>
				<slot />
			</main>
			<Footer />
		</div>
	</body>
</html>
