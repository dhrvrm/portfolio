---
import type { CollectionEntry } from 'astro:content';

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const isFeatured = Boolean(post.data.featured && !post.data.series);
const cardClass = [
	'group blog-card rounded-2xl overflow-hidden border border-border/70 hover:border-accent/60 transition-all duration-300 bg-surface/70',
	isFeatured ? 'blog-card--featured' : '',
]
	.filter(Boolean)
	.join(' ');
---

<a href={`/blog/${post.slug}`} class={cardClass}>
	{post.data.image && (
		<div class='aspect-video overflow-hidden'>
			<img
				src={post.data.image}
				alt={post.data.title}
				width='640'
				height='360'
				loading='lazy'
				decoding='async'
				class='w-full h-full object-cover group-hover:scale-105 transition-transform duration-300'
			/>
		</div>
	)}
	<div class='p-6'>
		<div class='flex flex-wrap gap-1.5 mb-4 items-center'>
			<span class='border border-border/70 text-muted px-2 py-0.5 rounded-full text-xs font-medium leading-tight'>
				{post.data.categories[0]}
			</span>
			{post.data.series && (
				<span class='border border-border/70 text-muted px-2 py-0.5 rounded-full text-xs'>
					{post.data.series} · Part {post.data.seriesPart}
				</span>
			)}
		</div>
		<h3 class='text-lg font-semibold mb-3 group-hover:text-ink transition-colors line-clamp-2'>
			{post.data.title}
		</h3>
		<p class='text-sm text-muted mb-4 line-clamp-3 leading-relaxed'>
			{post.data.excerpt}
		</p>
		<div class='flex justify-between items-center'>
			<span class='text-xs text-muted'>
				{new Date(post.data.publishDate).toLocaleDateString('en-US', {
					year: 'numeric',
					month: 'short',
					day: 'numeric',
				})}
			</span>
			<span class='sr-only'>Read more</span>
			<span class='text-accent group-hover:translate-x-1 transition-transform text-sm font-medium'>
				→
			</span>
		</div>
	</div>
</a>

<style>
	.blog-card--featured {
		border-top: 3px solid rgb(var(--color-accent) / 0.6);
	}
</style>
