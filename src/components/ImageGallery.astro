---
interface ImageItem {
	src: string;
	alt?: string;
	caption?: string;
}

interface Props {
	images: ImageItem[];
	class?: string;
}

const { images, class: className } = Astro.props;
const count = images.length;
const id = `ig-${Math.random().toString(36).slice(2, 9)}`;
---

{
	count > 0 && (
		<div class:list={['ig', className]} data-image-gallery={id}>
			{images.map((img, i) => (
				<button class='ig__cell' type='button' data-ig-open={i}>
					<img
						class='ig__cell-bg'
						src={img.src}
						alt=''
						aria-hidden='true'
						loading='lazy'
						draggable='false'
						decoding='async'
					/>
					<span class='ig__cell-inner'>
						<img
							src={img.src}
							alt={img.alt || ''}
							loading='lazy'
							draggable='false'
							decoding='async'
						/>
					</span>
				</button>
			))}
		</div>
	)
}

<dialog class='ig-dialog' data-ig-dialog={id}>
	<div class='ig-dialog__inner'>
		<button
			class='ig-dialog__close'
			type='button'
			data-ig-close
			aria-label='Close'
		>
			<svg width='20' height='20' viewBox='0 0 20 20' fill='none'>
				<path
					d='M5 5l10 10M15 5L5 15'
					stroke='currentColor'
					stroke-width='1.5'
					stroke-linecap='round'></path>
			</svg>
		</button>

		<button
			class='ig-dialog__arrow ig-dialog__arrow--prev'
			type='button'
			data-ig-prev
			aria-label='Previous'
		>
			<svg width='22' height='22' viewBox='0 0 22 22' fill='none'>
				<path
					d='M13 5L7 11l6 6'
					stroke='currentColor'
					stroke-width='1.5'
					stroke-linecap='round'
					stroke-linejoin='round'></path>
			</svg>
		</button>

		<div class='ig-dialog__stage'>
			<img class='ig-dialog__bg' data-ig-bg alt='' aria-hidden='true' />
			<img class='ig-dialog__img' data-ig-img alt='' />
			<p class='ig-dialog__caption' data-ig-caption></p>
		</div>

		<button
			class='ig-dialog__arrow ig-dialog__arrow--next'
			type='button'
			data-ig-next
			aria-label='Next'
		>
			<svg width='22' height='22' viewBox='0 0 22 22' fill='none'>
				<path
					d='M9 5l6 6-6 6'
					stroke='currentColor'
					stroke-width='1.5'
					stroke-linecap='round'
					stroke-linejoin='round'></path>
			</svg>
		</button>

		<span class='ig-dialog__counter' data-ig-counter></span>
	</div>
</dialog>

<style>
	/* Responsive grid: mixed aspect ratios, no cropping (object-fit: contain) */
	.ig {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(min(200px, 100%), 1fr));
		grid-auto-rows: auto;
		gap: 0.75rem;
		border-radius: var(--radius-lg);
		overflow: hidden;
	}

	@media (min-width: 640px) {
		.ig {
			grid-template-columns: repeat(auto-fill, minmax(min(240px, 100%), 1fr));
			gap: 1rem;
		}
	}

	@media (min-width: 1024px) {
		.ig {
			grid-template-columns: repeat(auto-fill, minmax(min(280px, 100%), 1fr));
		}
	}

	.ig__cell {
		position: relative;
		border: none;
		padding: 0;
		cursor: pointer;
		overflow: hidden;
		background: rgb(var(--color-border) / 0.12);
		border-radius: var(--radius-md);
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 120px;
		transition: background 0.2s ease;
	}

	.ig__cell:hover {
		background: rgb(var(--color-border) / 0.2);
	}

	/* Blurred extension of image fills letterbox space for horizontal images */
	.ig__cell-bg {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		filter: blur(24px);
		transform: scale(1.15);
		opacity: 0.9;
		z-index: 0;
	}

	.ig__cell-inner {
		position: relative;
		z-index: 1;
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
	}

	.ig__cell img {
		width: 100%;
		height: auto;
		max-height: min(360px, 65vh);
		object-fit: contain;
		object-position: center;
		display: block;
		transition: transform 0.35s ease;
		pointer-events: none;
	}

	.ig__cell:hover img {
		transform: scale(1.02);
	}

	@media (min-width: 640px) {
		.ig__cell img {
			max-height: min(440px, 70vh);
		}
	}

	@media (min-width: 1024px) {
		.ig__cell img {
			max-height: min(520px, 72vh);
		}
	}

	/* ── Dialog (native modal) ── */
	.ig-dialog {
		border: none;
		padding: 0;
		background: transparent;
		max-width: 100vw;
		max-height: 100vh;
		width: 100vw;
		height: 100vh;
		overflow: hidden;
	}

	.ig-dialog::backdrop {
		background: rgb(0 0 0 / 0.85);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
	}

	.ig-dialog__inner {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1rem;
		padding: 1rem;
		position: relative;
	}

	.ig-dialog__close {
		position: absolute;
		top: 1rem;
		right: 1rem;
		z-index: 2;
		width: 40px;
		height: 40px;
		border-radius: 999px;
		border: 1px solid rgb(255 255 255 / 0.15);
		background: rgb(255 255 255 / 0.08);
		color: #fff;
		display: grid;
		place-items: center;
		cursor: pointer;
		transition: background 0.2s ease;
	}

	.ig-dialog__close:hover {
		background: rgb(255 255 255 / 0.18);
	}

	.ig-dialog__arrow {
		flex-shrink: 0;
		width: 44px;
		height: 44px;
		border-radius: 999px;
		border: 1px solid rgb(255 255 255 / 0.15);
		background: rgb(255 255 255 / 0.06);
		color: #fff;
		display: grid;
		place-items: center;
		cursor: pointer;
		transition:
			background 0.2s ease,
			border-color 0.2s ease;
	}

	.ig-dialog__arrow:hover {
		background: rgb(255 255 255 / 0.14);
		border-color: rgb(255 255 255 / 0.3);
	}

	.ig-dialog__stage {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.75rem;
		max-width: min(85vw, 900px);
		max-height: 85vh;
		min-width: 0;
		overflow: hidden;
		border-radius: var(--radius-md);
	}

	/* Blurred image fills empty space around horizontal images in lightbox */
	.ig-dialog__bg {
		position: absolute;
		inset: -20%;
		width: 140%;
		height: 140%;
		object-fit: cover;
		object-position: center;
		filter: blur(40px);
		opacity: 0.85;
		z-index: 0;
	}

	.ig-dialog__img {
		position: relative;
		z-index: 1;
		max-width: 100%;
		max-height: 75vh;
		object-fit: contain;
		border-radius: var(--radius-sm);
	}

	.ig-dialog__caption {
		position: relative;
		z-index: 1;
		font-size: 0.82rem;
		color: rgb(255 255 255 / 0.7);
		text-align: center;
		margin: 0;
		max-width: 500px;
	}

	.ig-dialog__caption:empty {
		display: none;
	}

	.ig-dialog__counter {
		position: absolute;
		top: 1.2rem;
		left: 50%;
		transform: translateX(-50%);
		font-size: 0.75rem;
		color: rgb(255 255 255 / 0.5);
		font-variant-numeric: tabular-nums;
	}

	@media (max-width: 640px) {
		.ig-dialog__arrow {
			width: 36px;
			height: 36px;
		}

		.ig-dialog__stage {
			max-width: 92vw;
		}

		.ig-dialog__img {
			max-height: 65vh;
		}
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		document
			.querySelectorAll<HTMLElement>('[data-image-gallery]')
			.forEach((grid) => {
				const id = grid.dataset.imageGallery;
				const dialog = document.querySelector<HTMLDialogElement>(
					`[data-ig-dialog="${id}"]`,
				);
				if (!dialog) return;

				const img = dialog.querySelector<HTMLImageElement>('[data-ig-img]');
				const bgImg = dialog.querySelector<HTMLImageElement>('[data-ig-bg]');
				const caption = dialog.querySelector<HTMLElement>('[data-ig-caption]');
				const counter = dialog.querySelector<HTMLElement>('[data-ig-counter]');
				const closeBtn = dialog.querySelector('[data-ig-close]');
				const prevBtn = dialog.querySelector('[data-ig-prev]');
				const nextBtn = dialog.querySelector('[data-ig-next]');

				// Build image data from the grid's button cells
				const cells = Array.from(
					grid.querySelectorAll<HTMLButtonElement>('[data-ig-open]'),
				);

				const allImages: { src: string; caption: string }[] = [];
				cells.forEach((cell) => {
					const cellImg = cell.querySelector('img');
					if (cellImg) {
						allImages.push({
							src: cellImg.getAttribute('src') || '',
							caption: cellImg.getAttribute('alt') || '',
						});
					}
				});

				// Also read from the server-rendered data via the dialog's sibling script data
				// For overflow images, we'll need to handle them differently
				const total = allImages.length;
				if (total === 0) return;

				let current = 0;

				function show(index: number) {
					current = ((index % total) + total) % total;
					const src = allImages[current].src;
					if (img) {
						img.src = src;
						img.alt = allImages[current].caption || 'Gallery image';
					}
					if (bgImg) bgImg.src = src;
					if (caption) caption.textContent = allImages[current].caption;
					if (counter) counter.textContent = `${current + 1} / ${total}`;
				}

				cells.forEach((cell) => {
					cell.addEventListener('click', () => {
						const idx = parseInt(cell.dataset.igOpen || '0', 10);
						show(idx);
						dialog.showModal();
					});
				});

				closeBtn?.addEventListener('click', () => dialog.close());
				prevBtn?.addEventListener('click', () => show(current - 1));
				nextBtn?.addEventListener('click', () => show(current + 1));

				dialog.addEventListener('keydown', (e) => {
					if (e.key === 'ArrowLeft') show(current - 1);
					if (e.key === 'ArrowRight') show(current + 1);
				});

				// Close when clicking backdrop (outside dialog content)
				dialog.addEventListener('click', (e) => {
					if (e.target === dialog) dialog.close();
				});
			});
	});
</script>
