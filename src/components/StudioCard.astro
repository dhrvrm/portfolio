---
interface Props {
	eyebrow?: string;
	title: string;
	body: string;
	/** Short personality line (e.g. "One bag. Many time zones.") */
	kicker?: string;
	href?: string;
	variant?: 'default' | 'asymmetric';
}

const { eyebrow, title, body, kicker, href, variant = 'default' } = Astro.props;

const baseClass =
	variant === 'asymmetric'
		? 'studio-card studio-card--asymmetric'
		: 'studio-card';
const Wrapper = href ? 'a' : 'div';
const wrapperProps = href ? { href } : { tabindex: 0 };
---

<Wrapper class={baseClass} {...wrapperProps}>
	<span class='studio-card__spotlight' aria-hidden='true'></span>
	{eyebrow && (
		<span class='studio-card__eyebrow'>
			<span class='studio-card__tick' aria-hidden='true'></span>
			{eyebrow}
		</span>
	)}
	<h3 class='studio-card__title'>{title}</h3>
	<p class='studio-card__body'>{body}</p>
	{kicker && (
		<p class='studio-card__kicker'>
			<span>{kicker}</span>
			<span class='studio-card__arrow' aria-hidden='true'>&rarr;</span>
		</p>
	)}
</Wrapper>

<style>
	.studio-card {
		display: flex;
		flex-direction: column;
		height: 100%;
		position: relative;
		isolation: isolate;
		overflow: hidden;
		padding: 1.75rem;
		border-radius: var(--radius-xl);
		border: 1px solid rgb(var(--color-border) / 0.7);
		background: rgb(var(--color-surface) / 0.7);
		/* Material depth: lit top edge + soft tinted lift */
		box-shadow:
			inset 0 1px 0 rgb(255 255 255 / 0.04),
			var(--shadow-card);
		transition:
			transform 0.3s ease,
			border-color 0.3s ease,
			box-shadow 0.3s ease;
		text-decoration: none;
		color: inherit;
	}

	.studio-card:hover {
		border-color: rgb(var(--color-accent) / 0.5);
		box-shadow:
			inset 0 1px 0 rgb(255 255 255 / 0.06),
			var(--shadow-card-hover);
	}

	.studio-card:focus-visible {
		outline: 2px solid rgb(var(--color-accent));
		outline-offset: 3px;
	}

	.studio-card--asymmetric {
		border-radius: var(--radius-xl) var(--radius-lg) var(--radius-xl)
			var(--radius-lg);
	}

	/* Cursor spotlight: lights the surface where the pointer is (desktop only).
	   Position fed by --spot-x / --spot-y from the personality-cards handler. */
	.studio-card__spotlight {
		position: absolute;
		inset: 0;
		z-index: 0;
		border-radius: inherit;
		pointer-events: none;
		opacity: 0;
		background: radial-gradient(
			220px circle at var(--spot-x, 50%) var(--spot-y, 0%),
			rgb(var(--color-accent) / 0.1),
			transparent 70%
		);
		transition: opacity 0.35s ease;
	}

	@media (hover: hover) and (pointer: fine) {
		.studio-card:hover .studio-card__spotlight {
			opacity: 1;
		}
	}

	.studio-card__eyebrow,
	.studio-card__title,
	.studio-card__body,
	.studio-card__kicker {
		position: relative;
		z-index: 1;
	}

	.studio-card__eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 0.625rem;
		font-family: var(--font-mono);
		text-transform: uppercase;
		letter-spacing: 0.12em;
		font-size: 0.7rem;
		color: rgb(var(--color-muted));
	}

	.studio-card__tick {
		display: inline-block;
		width: 1.5rem;
		height: 1px;
		background: rgb(var(--color-accent));
		transition: width 0.3s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.studio-card:hover .studio-card__tick {
		width: 2.25rem;
	}

	.studio-card__title {
		margin-top: 0.85rem;
		font-size: 1.3rem;
		font-weight: 600;
		line-height: 1.25;
		letter-spacing: -0.01em;
	}

	.studio-card__body {
		margin-top: 0.75rem;
		font-size: 0.95rem;
		color: rgb(var(--color-muted));
		line-height: 1.6;
	}

	/* Kicker pinned to the card foot, separated by a hairline */
	.studio-card__kicker {
		margin-top: auto;
		padding-top: 1rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		border-top: 1px solid rgb(var(--color-border) / 0.7);
		font-size: 0.8125rem;
		font-weight: 500;
		color: rgb(var(--color-accent));
		line-height: 1.4;
	}

	.studio-card__body + .studio-card__kicker {
		margin-top: 1.5rem;
	}

	.studio-card__arrow {
		flex-shrink: 0;
		transition: transform 0.25s ease;
	}

	.studio-card:hover .studio-card__arrow {
		transform: translateX(4px);
	}

	@media (prefers-reduced-motion: reduce) {
		.studio-card,
		.studio-card__tick,
		.studio-card__arrow,
		.studio-card__spotlight {
			transition: none;
		}
	}
</style>
