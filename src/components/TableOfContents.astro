---
const { headings } = Astro.props;
---

<nav class='toc pl-2 pr-4'>
	<h2 class='text-sm font-semibold uppercase tracking-[0.2em] text-muted mb-4'>
		On this page
	</h2>
	<ul class='space-y-2'>
		{
			headings.map((heading) => (
				<li class='pl-4' style={`margin-left: ${(heading.depth - 1) * 1}rem`}>
					<a
						href={`#${heading.slug}`}
						class='text-sm text-muted hover:text-ink transition-colors'
					>
						{heading.text}
					</a>
				</li>
			))
		}
	</ul>
</nav>

<style>
	.toc {
		position: sticky;
		top: 6rem;
		max-height: calc(100vh - 8rem);
		overflow-y: auto;
		padding-top: 1rem;
		padding-bottom: 1rem;
		margin-left: -0.5rem;
	}

	/* Custom Scrollbar for TableOfContents */
	.toc::-webkit-scrollbar {
		width: 6px;
	}

	.toc::-webkit-scrollbar-track {
		background: transparent;
	}

	.toc::-webkit-scrollbar-thumb {
		background-color: rgb(var(--color-ink) / 0.15);
		border-radius: 9999px;
	}

	.toc::-webkit-scrollbar-thumb:hover {
		background-color: rgb(var(--color-ink) / 0.25);
	}

	/* Dark theme specific styles */
	:root.dark .toc::-webkit-scrollbar-thumb {
		background-color: rgb(var(--color-ink) / 0.2);
	}

	:root.dark .toc::-webkit-scrollbar-thumb:hover {
		background-color: rgb(var(--color-ink) / 0.3);
	}

	/* Firefox */
	.toc {
		scrollbar-width: thin;
		scrollbar-color: rgb(var(--color-ink) / 0.2) transparent;
	}

	:root.dark .toc {
		scrollbar-color: rgb(var(--color-ink) / 0.25) transparent;
	}
</style>
