---
import { getCollection } from 'astro:content';
import { slugify } from '../utils/content';

interface Props {
	/** Href for the "All posts" link in the Recent box; omit or null to hide it. */
	allPostsLink?: string | null;
}

const { allPostsLink = null } = Astro.props;

const posts = await getCollection('blog');

const categories = [...new Set(posts.flatMap((p) => p.data.categories))];
const tags = [...new Set(posts.flatMap((p) => p.data.tags ?? []))];
const categoryCounts = categories.reduce(
	(acc, cat) => {
		acc[cat] = posts.filter((p) => p.data.categories.includes(cat)).length;
		return acc;
	},
	{} as Record<string, number>,
);

const recentPosts = [...posts]
	.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
	.slice(0, 5);

const SIDEBAR_TAGS_SHOW = 15;
const tagsPreview = tags.slice(0, SIDEBAR_TAGS_SHOW);
const tagsMore = tags.length > SIDEBAR_TAGS_SHOW;
---

<aside class='space-y-8' aria-label='Blog categories and navigation'>
	<div class='bg-surface/70 rounded-2xl p-6 border border-border/70'>
		<h2 class='text-lg font-semibold mb-4'>Categories</h2>
		<ul class='space-y-2 max-h-48 overflow-y-auto'>
			{categories.map((category) => (
				<li>
					<span class='text-sm text-muted flex items-center justify-between'>
						<span>{category}</span>
						<span class='text-xs bg-surface border border-border/70 text-muted px-2 py-1 rounded-full'>
							{categoryCounts[category]}
						</span>
					</span>
				</li>
			))}
		</ul>
	</div>
	<div class='bg-surface/70 rounded-2xl p-6 border border-border/70'>
		<h2 class='text-lg font-semibold mb-4'>Recent posts</h2>
		<ul class='space-y-4'>
			{recentPosts.map((post) => (
				<li>
					<a href={`/blog/${post.slug}`} class='group block'>
						<h3 class='text-sm font-medium group-hover:text-ink transition-colors line-clamp-2'>
							{post.data.title}
						</h3>
						<p class='text-xs text-muted mt-0.5'>
							{new Date(post.data.publishDate).toLocaleDateString('en-US', {
								month: 'short',
								day: 'numeric',
								year: 'numeric',
							})}
						</p>
					</a>
				</li>
			))}
		</ul>
		{allPostsLink && (
			<a
				href={allPostsLink}
				class='mt-4 inline-block text-sm font-medium text-accent hover:text-accentStrong'
			>
				All posts →
			</a>
		)}
	</div>
	<div class='bg-surface/70 rounded-2xl p-6 border border-border/70'>
		<h2 class='text-lg font-semibold mb-4'>Tags</h2>
		<div class='flex flex-wrap gap-2'>
			{tagsPreview.map((tag) => (
				<a
					href={`/blog/tag/${slugify(tag)}`}
					class='text-xs px-3 py-1 rounded-full border border-border/70 text-muted hover:text-ink hover:border-accent transition-colors'
				>
					{tag}
				</a>
			))}
		</div>
		{tagsMore && (
			<details class='mt-3'>
				<summary class='cursor-pointer text-xs text-muted hover:text-ink transition-colors'>Show more tags</summary>
				<div class='flex flex-wrap gap-2 mt-2'>
					{tags.slice(SIDEBAR_TAGS_SHOW).map((tag) => (
						<a
							href={`/blog/tag/${slugify(tag)}`}
							class='text-xs px-3 py-1 rounded-full border border-border/70 text-muted hover:text-ink hover:border-accent transition-colors'
						>
							{tag}
						</a>
					))}
				</div>
			</details>
		)}
	</div>
</aside>
