---
import type { CollectionEntry } from 'astro:content';
import StudioBadge from './StudioBadge.astro';

interface Props {
	item: CollectionEntry<'activities'>;
	showNarrative?: boolean;
	variant?: 'default' | 'asymmetric';
}

const { item, showNarrative = false, variant = 'default' } = Astro.props;
const media = item.data.images ?? [];
const labelMap: Record<string, string> = {
	events: 'Event',
	hackathons: 'Hackathon',
	speaking: 'Speaking',
	awards: 'Award',
	travel: 'Travel',
};
const hackathonLabel: Record<string, string> = {
	participated: 'Participated',
	mentored: 'Coached',
	judged: 'Judged',
};
const label =
	item.data.category === 'hackathons' && item.data.hackathonType
		? hackathonLabel[item.data.hackathonType]
		: (labelMap[item.data.category] ?? 'Activity');
const badgeVariant =
	item.data.category === 'hackathons' && item.data.hackathonType
		? item.data.hackathonType
		: 'default';
const href = `/activities/${item.slug}`;
const cardClass = [
	'activity-card',
	variant === 'asymmetric' ? 'activity-card--asymmetric' : '',
]
	.filter(Boolean)
	.join(' ');
---

<a class={cardClass} href={href}>
	{
		(media.length > 0 || item.data.video) && (
			<div class='activity-card__media'>
				{item.data.video ? (
					<video
						class='activity-card__video'
						src={item.data.video}
						poster={media[0]}
						controls
						preload='metadata'
					/>
				) : (
					<img
						class='activity-card__image'
						src={media[0]}
						alt={item.data.title}
						width='360'
						height='180'
						loading='lazy'
					/>
				)}
				{media.length > 1 && (
					<div class='activity-card__thumbs'>
						{media.slice(1, 3).map((image, i) => (
							<img src={image} alt={`${item.data.title}, image ${i + 2}`} width='46' height='46' loading='lazy' />
						))}
					</div>
				)}
			</div>
		)
	}
	<div class='activity-card__body'>
		<div class='activity-card__meta'>
			<StudioBadge label={label} variant={badgeVariant} />
			{item.data.video && <span class='activity-card__tag'>Video</span>}
		</div>
		<h3 class='activity-card__title'>{item.data.title}</h3>
		<p class='text-sm text-muted mt-2 line-clamp-2'>{item.data.summary}</p>
		{
			showNarrative && item.data.narrative && (
				<p class='activity-card__narrative'>{item.data.narrative}</p>
			)
		}
		<div class='activity-card__foot'>
			<p class='activity-card__foot-meta'>
				{item.data.role} · {item.data.location} · {
					item.data.date.toLocaleDateString('en-US', {
						year: 'numeric',
						month: 'short',
						day: 'numeric',
					})
				}
			</p>
			<span class='activity-card__arrow' aria-hidden='true'>&rarr;</span>
		</div>
	</div>
</a>

<style>
	.activity-card {
		border-radius: var(--radius-xl);
		border: 1px solid rgb(var(--color-border) / 0.7);
		background: rgb(var(--color-surface) / 0.7);
		padding: 0;
		transition:
			transform 0.3s ease,
			border-color 0.3s ease,
			box-shadow 0.3s ease;
		position: relative;
		overflow: hidden;
		text-decoration: none;
		color: inherit;
		display: block;
	}

	.activity-card:hover {
		transform: translateY(-4px);
		border-color: rgb(var(--color-accent) / 0.5);
		box-shadow: var(--shadow-soft);
	}

	.activity-card--asymmetric {
		border-radius: var(--radius-lg) var(--radius-xl) var(--radius-lg)
			var(--radius-xl);
	}

	.activity-card__body {
		padding: 1.5rem;
	}

	.activity-card__media {
		overflow: hidden;
		background: rgb(var(--color-border) / 0.2);
		position: relative;
		margin: -1px -1px 0 -1px;
		width: calc(100% + 2px);
		border-radius: var(--radius-xl) var(--radius-xl) 0 0;
	}

	.activity-card--asymmetric .activity-card__media {
		border-radius: var(--radius-lg) var(--radius-xl) 0 0;
	}

	.activity-card__image,
	.activity-card__video {
		width: 100%;
		height: 180px;
		object-fit: cover;
		display: block;
	}

	.activity-card__image {
		transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.activity-card:hover .activity-card__image {
		transform: scale(1.04);
	}

	.activity-card__thumbs {
		position: absolute;
		right: 12px;
		bottom: 12px;
		display: grid;
		gap: 6px;
	}

	.activity-card__thumbs img {
		width: 46px;
		height: 46px;
		border-radius: var(--radius-md);
		object-fit: cover;
		border: 1px solid rgb(var(--color-border) / 0.6);
		background: rgb(var(--color-surface));
	}

	.activity-card__meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 0.75rem;
	}

	.activity-card__tag {
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		color: rgb(var(--color-muted));
		border: 1px dashed rgb(var(--color-border));
		padding: 0.15rem 0.5rem;
		border-radius: 999px;
	}

	.activity-card__title {
		font-weight: 600;
		line-height: 1.3;
	}

	/* Footer affordance: bottom arrow nudges on hover (site-wide card convention) */
	.activity-card__arrow {
		flex-shrink: 0;
		color: rgb(var(--color-accent));
		transition: transform 0.25s ease;
	}

	.activity-card:hover .activity-card__arrow {
		transform: translateX(4px);
	}

	/* Narrative: a tinted block, not a side-stripe quote */
	.activity-card__narrative {
		margin-top: 1rem;
		padding: 0.75rem 0.9rem;
		border-radius: var(--radius-md);
		background: rgb(var(--color-border) / 0.2);
		font-size: 0.85rem;
		font-style: italic;
		line-height: 1.5;
		color: rgb(var(--color-muted));
	}

	.activity-card__foot {
		margin-top: 1.25rem;
		padding-top: 1rem;
		border-top: 1px solid rgb(var(--color-border) / 0.5);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.activity-card__foot-meta {
		min-width: 0;
		margin: 0;
		font-size: 0.75rem;
		color: rgb(var(--color-muted));
	}

	@media (prefers-reduced-motion: reduce) {
		.activity-card,
		.activity-card__image,
		.activity-card__arrow {
			transition: none;
		}
		.activity-card:hover {
			transform: none;
		}
		.activity-card:hover .activity-card__image {
			transform: none;
		}
	}
</style>
