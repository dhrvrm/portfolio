---
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
	{ href: '/', text: 'Home' },
	{ href: '/projects', text: 'Work' },
	{ href: '/experience', text: 'Experience' },
	{ href: '/activities', text: 'Activities' },
	{ href: '/blog', text: 'Writing' },
	{ href: '/contact', text: 'Contact' },
];
---

<header class='fixed top-0 left-0 right-0 z-50'>
	<nav class='max-w-7xl mx-auto px-6 py-4'>
		<div
			class='backdrop-blur-lg bg-surface/90 border border-border/70 rounded-2xl px-5 py-3 flex items-center justify-between shadow-[var(--shadow-soft)]'
		>
			<a href='/' class='text-lg md:text-xl font-semibold font-display tracking-tight'>
				Dhruv Verma
			</a>

			<div class='hidden md:flex items-center gap-7'>
				{
					navItems.map((item) => (
						<a
							href={item.href}
							class='text-sm font-medium text-muted hover:text-ink transition-colors'
						>
							{item.text}
						</a>
					))
				}
				<ThemeToggle />
			</div>

			<button
				id='mobile-menu-toggle'
				class='md:hidden inline-flex items-center justify-center rounded-lg border border-border/70 px-3 py-2 text-sm text-ink'
				aria-label='Toggle menu'
				aria-expanded='false'
				aria-controls='mobile-menu'
			>
				Menu
			</button>
		</div>
		<div
			id='mobile-menu'
			class='md:hidden mt-3 bg-surface/95 border border-border/70 rounded-2xl p-4 shadow-[var(--shadow-soft)] hidden'
		>
			<div class='flex flex-col gap-3'>
				{
					navItems.map((item) => (
						<a href={item.href} class='text-sm font-medium text-muted hover:text-ink'>
							{item.text}
						</a>
					))
				}
				<div class='pt-2 border-t border-border/70'>
					<ThemeToggle />
				</div>
			</div>
		</div>
	</nav>
</header>

<script>
	document.addEventListener('astro:page-load', () => {
		const toggle = document.getElementById('mobile-menu-toggle');
		const menu = document.getElementById('mobile-menu');
		if (!toggle || !menu) return;

		const setOpen = (isOpen) => {
			toggle.setAttribute('aria-expanded', String(isOpen));
			menu.classList.toggle('hidden', !isOpen);
		};

		setOpen(false);

		toggle.addEventListener('click', () => {
			const isOpen = toggle.getAttribute('aria-expanded') === 'true';
			setOpen(!isOpen);
		});

		menu.querySelectorAll('a').forEach((link) => {
			link.addEventListener('click', () => setOpen(false));
		});
	});
</script>
