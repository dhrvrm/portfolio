---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
	project: CollectionEntry<'projects'>;
	/** Big horizontal feature card (image beside the story) vs standard vertical card */
	feature?: boolean;
	/** Eager-load the image (use for above-the-fold cards) */
	eager?: boolean;
}

const { project, feature = false, eager = false } = Astro.props;
const categoryLabel =
	project.data.category === 'client' ? 'Client work' : 'Personal project';
const techShown = feature ? 4 : 3;
const extra = project.data.tech.length - techShown;
---

<a
	href={`/projects/${project.slug}`}
	class:list={['proj-card group', { 'proj-card--feature': feature }]}
>
	<div class='proj-card__media'>
		<Image
			width={feature ? 720 : 480}
			height={feature ? 405 : 270}
			src={project.data.image}
			alt={`${project.data.title}, project preview`}
			loading={eager ? 'eager' : 'lazy'}
			class='proj-img'
		/>
	</div>
	<div class='proj-card__body'>
		<span class='proj-cat'>{categoryLabel}</span>
		<h2
			class:list={[
				'proj-card__title',
				{ 'proj-card__title--feature': feature },
			]}
		>
			{project.data.title}
		</h2>
		<p class='proj-card__desc'>{project.data.description}</p>
		<div class='proj-pills'>
			{project.data.tech.slice(0, techShown).map((tech) => (
				<span class='proj-pill'>{tech}</span>
			))}
			{extra > 0 && <span class='proj-pill'>+{extra} more</span>}
		</div>
		<!-- Footer affordance: site-wide convention is a bottom arrow that nudges on hover -->
		<div class='proj-card__foot'>
			<span class='proj-card__go'>
				{feature ? 'View project' : 'Case study'}
			</span>
			<span class='proj-card__arrow' aria-hidden='true'>&rarr;</span>
		</div>
	</div>
</a>

<style>
	.proj-card {
		display: block;
		position: relative;
		overflow: hidden;
		height: 100%;
		border-radius: var(--radius-xl);
		border: 1px solid rgb(var(--color-border) / 0.7);
		background: rgb(var(--color-surface) / 0.7);
		text-decoration: none;
		color: inherit;
		transition:
			transform 0.3s ease,
			border-color 0.3s ease,
			box-shadow 0.3s ease;
	}
	.proj-card:hover {
		transform: translateY(-4px);
		border-color: rgb(var(--color-accent) / 0.5);
		box-shadow: var(--shadow-soft);
	}

	.proj-card__media {
		overflow: hidden;
		background: rgb(var(--color-border) / 0.2);
		aspect-ratio: 16 / 9;
	}
	.proj-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.proj-card:hover .proj-img {
		transform: scale(1.04);
	}

	.proj-card__body {
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	.proj-cat {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: rgb(var(--color-muted));
	}

	.proj-card__title {
		margin-top: 0.6rem;
		font-size: 1.2rem;
		font-weight: 600;
		line-height: 1.25;
		color: rgb(var(--color-ink));
	}
	.proj-card__desc {
		margin-top: 0.5rem;
		font-size: 0.9375rem;
		line-height: 1.55;
		color: rgb(var(--color-muted));
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.proj-pills {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-top: 1.25rem;
	}
	.proj-pill {
		padding: 0.25rem 0.7rem;
		border-radius: 9999px;
		font-size: 0.75rem;
		border: 1px solid rgb(var(--color-border) / 0.7);
		color: rgb(var(--color-muted));
	}

	/* Footer affordance */
	.proj-card__foot {
		margin-top: 1.5rem;
		padding-top: 1.25rem;
		border-top: 1px solid rgb(var(--color-border) / 0.5);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.proj-card__go {
		font-size: 0.8125rem;
		font-weight: 600;
		color: rgb(var(--color-accent));
	}
	.proj-card__arrow {
		flex-shrink: 0;
		color: rgb(var(--color-accent));
		transition: transform 0.25s ease;
	}
	.proj-card:hover .proj-card__arrow {
		transform: translateX(4px);
	}

	/* Feature variant: image beside the story on desktop */
	@media (min-width: 1024px) {
		.proj-card--feature {
			display: grid;
			grid-template-columns: 1.05fr 1fr;
			align-items: stretch;
		}
		.proj-card--feature .proj-card__media {
			aspect-ratio: auto;
			height: 100%;
			min-height: 340px;
		}
		.proj-card--feature .proj-card__body {
			padding: 2.5rem;
		}
	}
	.proj-card__title--feature {
		font-family: 'Space Grotesk Variable', 'Inter Variable', system-ui, sans-serif;
		font-size: clamp(1.5rem, 1.2rem + 1.4vw, 2rem);
		letter-spacing: -0.02em;
		line-height: 1.15;
	}
	.proj-card--feature .proj-card__desc {
		font-size: 1rem;
		line-height: 1.6;
		max-width: 48ch;
		-webkit-line-clamp: 3;
	}

	@media (prefers-reduced-motion: reduce) {
		.proj-card,
		.proj-img,
		.proj-card__arrow {
			transition: none;
		}
		.proj-card:hover {
			transform: none;
		}
		.proj-card:hover .proj-img {
			transform: none;
		}
	}
</style>
