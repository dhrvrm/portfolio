---
/**
 * Scroll-triggered curved image gallery.
 * Images are distributed around a large circle; as the user scrolls,
 * the wheel rotates and images travel along a curved arc.
 * The section pins until the full rotation completes.
 */
interface ImageItem {
	src: string;
	alt?: string;
}

interface Props {
	images: ImageItem[];
	id: string;
}

const { images, id } = Astro.props;

/* Ensure at least 16 items for a rich wheel – duplicate if needed */
const MIN_CARDS = 16;
const deck =
	images.length >= MIN_CARDS
		? images
		: Array.from({ length: MIN_CARDS }, (_, i) => images[i % images.length]);
const count = deck.length;
---

{
	count > 0 && (
		<div class='sg-pin' data-sg-pin={id}>
			<div class='sg-bleed'>
				<div class='sg-viewport'>
					<div class='sg-wheel' data-sg-wheel>
						{deck.map((img) => (
							<div class='sg-card' data-sg-card>
								<img
									src={img.src}
									alt={img.alt || ''}
									loading='lazy'
									draggable='false'
								/>
							</div>
						))}
					</div>
				</div>
			</div>
		</div>
	)
}

<style>
	/*
	 * .sg-pin  - normal-flow wrapper. This is what GSAP pins.
	 *            NO negative margins, NO width:100vw.
	 * .sg-bleed - child that breaks out to full viewport width.
	 */
	.sg-pin {
		position: relative;
	}

	.sg-bleed {
		width: 100vw;
		margin-left: calc(50% - 50vw);
	}

	.sg-viewport {
		height: clamp(260px, 38vh, 420px);
		overflow: hidden;
		position: relative;
		mask: linear-gradient(90deg, transparent, #fff 6% 94%, transparent);
		-webkit-mask: linear-gradient(90deg, transparent, #fff 6% 94%, transparent);
	}

	.sg-wheel {
		position: absolute;
		top: 0;
		left: 50%;
		transform: translateX(-50%);
		width: 280vw;
		height: 280vw;
		max-width: 2200px;
		max-height: 2200px;
	}

	.sg-card {
		position: absolute;
		top: 0;
		left: 0;
		width: clamp(80px, 6.5%, 170px);
		aspect-ratio: 7 / 10;
	}

	.sg-card img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: var(--radius-sm);
		box-shadow: 0 6px 24px rgb(0 0 0 / 0.25);
		border: 1px solid rgb(var(--color-border) / 0.3);
		pointer-events: none;
	}

	@media (max-width: 640px) {
		.sg-viewport {
			height: clamp(200px, 32vh, 320px);
		}

		.sg-wheel {
			width: 400vw;
			height: 400vw;
			max-width: none;
			max-height: none;
		}

		.sg-card {
			width: clamp(70px, 8%, 140px);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.sg-viewport {
			display: flex;
			overflow-x: auto;
			gap: 1rem;
			padding: 1rem;
			mask: none;
			-webkit-mask: none;
			height: auto;
		}

		.sg-wheel {
			position: static;
			width: auto;
			height: auto;
			display: flex;
			gap: 1rem;
			transform: none;
		}

		.sg-card {
			position: static;
			width: 140px;
			flex-shrink: 0;
		}
	}
</style>

<script>
	function initScrollGalleries() {
		const gsap = window.gsap;
		const ScrollTrigger = window.ScrollTrigger;
		if (!gsap || !ScrollTrigger) return;
		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

		document.querySelectorAll<HTMLElement>('[data-sg-pin]').forEach((pin) => {
			const wheel = pin.querySelector<HTMLElement>('[data-sg-wheel]');
			const cards = Array.from(
				pin.querySelectorAll<HTMLElement>('[data-sg-card]'),
			);
			if (!wheel || cards.length === 0) return;

			function positionCards() {
				const radius = wheel!.offsetWidth / 2;
				const center = radius;
				const slice = 360 / cards.length;
				const DEG2RAD = Math.PI / 180;

				gsap.set(cards, {
					x: (i: number) => center + radius * Math.sin(i * slice * DEG2RAD),
					y: (i: number) => center - radius * Math.cos(i * slice * DEG2RAD),
					rotation: (i: number) => i * slice,
					xPercent: -50,
					yPercent: -50,
				});
			}

			positionCards();

			gsap.to(wheel, {
				rotation: -360,
				ease: 'none',
				scrollTrigger: {
					trigger: pin,
					pin: true,
					anticipatePin: 1,
					start: 'top top',
					end: () => `+=${window.innerHeight * 2}`,
					scrub: 1,
					invalidateOnRefresh: true,
				},
			});
		});

		requestAnimationFrame(() => ScrollTrigger.refresh());
	}

	document.addEventListener('DOMContentLoaded', initScrollGalleries);
</script>
