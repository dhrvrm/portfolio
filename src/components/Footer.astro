---
const currentYear = new Date().getFullYear();

const navGroups = [
	{
		label: 'Work',
		items: [
			{ href: '/projects', text: 'Projects' },
			{ href: '/experience', text: 'Experience' },
		],
	},
	{
		label: 'Explore',
		items: [
			{ href: '/activities', text: 'Activities' },
			{ href: '/blog', text: 'Writing' },
		],
	},
	{
		label: 'Connect',
		items: [{ href: '/contact', text: 'Contact' }],
	},
];

const socialLinks = [
	{ name: 'GitHub', url: 'https://github.com/dhrvrm', aria: 'GitHub profile' },
	{ name: 'LinkedIn', url: 'https://www.linkedin.com/in/dhruvv', aria: 'LinkedIn profile' },
	{ name: 'Email', url: 'mailto:dhruvv@live.com', aria: 'Send email' },
	{ name: 'Twitter', url: 'https://twitter.com/verma1300', aria: 'Twitter profile' },
];
---

<footer class='footer'>
	<div class='footer__top'>
		<div class='footer__container'>
			<div class='footer__main'>
				<div class='footer__brand'>
					<a href='/' class='footer__name'>Dhruv Verma</a>
					<p class='footer__tagline'>
						Engineering thoughtful software. Building in the open.
					</p>
				</div>
				<div class='footer__nav'>
					{navGroups.map((group) => (
						<nav class='footer__group' aria-label={group.label}>
							<p class='footer__label'>{group.label}</p>
							<ul class='footer__links'>
								{group.items.map((item) => (
									<li>
										<a href={item.href} class='footer__link'>
											{item.text}
										</a>
									</li>
								))}
							</ul>
						</nav>
					))}
				</div>
				<div class='footer__social-wrap'>
					<p class='footer__label'>Social</p>
					<ul class='footer__social'>
						{socialLinks.map((link) => (
							<li>
								<a
									href={link.url}
									target='_blank'
									rel='noopener noreferrer'
									class='footer__social-link'
									aria-label={link.aria}
								>
									{link.name}
								</a>
							</li>
						))}
					</ul>
				</div>
			</div>
		</div>
	</div>
	<div class='footer__bottom'>
		<div class='footer__container footer__container--bottom'>
			<p class='footer__copy'>© {currentYear} Dhruv Verma</p>
			<a href='/' class='footer__back'>Back to top</a>
		</div>
	</div>
</footer>

<style>
	.footer {
		margin-top: 6rem;
	}

	/* Signature: rounded top cap + elevated surface, echoes header pill */
	.footer__top {
		background: rgb(var(--color-surface) / 0.6);
		border: 1px solid rgb(var(--color-border) / 0.7);
		border-bottom: none;
		border-radius: var(--radius-xl) var(--radius-xl) 0 0;
		box-shadow: var(--shadow-soft);
		padding: 3rem 0 2.5rem;
	}

	.footer__container {
		max-width: 72rem;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	.footer__main {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2.5rem 3rem;
	}

	@media (min-width: 640px) {
		.footer__main {
			grid-template-columns: minmax(0, 1.2fr) auto;
		}
		.footer__nav {
			display: flex;
			flex-wrap: wrap;
			gap: 2rem 2.5rem;
		}
	}

	@media (min-width: 1024px) {
		.footer__main {
			grid-template-columns: minmax(0, 1.4fr) 1fr auto;
			gap: 3rem 4rem;
		}
		.footer__nav {
			gap: 2.5rem 3rem;
		}
	}

	.footer__brand {
		max-width: 20rem;
	}

	.footer__name {
		display: inline-block;
		font-family: 'Space Grotesk Variable', 'Inter Variable', system-ui, sans-serif;
		font-size: 1.5rem;
		font-weight: 600;
		letter-spacing: -0.02em;
		color: rgb(var(--color-ink));
		text-decoration: none;
		transition: color 0.2s ease;
	}
	.footer__name:hover {
		color: rgb(var(--color-accent));
	}

	.footer__tagline {
		margin-top: 0.5rem;
		font-size: 0.9375rem;
		line-height: 1.5;
		color: rgb(var(--color-muted));
	}

	.footer__label {
		font-size: 0.6875rem;
		font-weight: 600;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: rgb(var(--color-muted));
		margin-bottom: 0.75rem;
	}

	.footer__links {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.footer__link {
		font-size: 0.9375rem;
		color: rgb(var(--color-muted));
		text-decoration: none;
		transition: color 0.2s ease;
		position: relative;
	}
	.footer__link:hover,
	.footer__link:focus-visible {
		color: rgb(var(--color-ink));
	}
	.footer__link::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: -2px;
		width: 0;
		height: 2px;
		background: rgb(var(--color-accent));
		transition: width 0.2s ease;
	}
	.footer__link:hover::after,
	.footer__link:focus-visible::after {
		width: 100%;
	}

	.footer__social-wrap {
		margin-top: 0.25rem;
	}

	.footer__social {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem 0.75rem;
	}

	.footer__social-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 2.5rem;
		height: 2.5rem;
		padding: 0 0.75rem;
		font-size: 0.8125rem;
		font-weight: 500;
		color: rgb(var(--color-muted));
		background: rgb(var(--color-bg) / 0.8);
		border: 1px solid rgb(var(--color-border) / 0.8);
		border-radius: var(--radius-lg);
		text-decoration: none;
		transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
	}
	.footer__social-link:hover,
	.footer__social-link:focus-visible {
		color: rgb(var(--color-ink));
		border-color: rgb(var(--color-accent) / 0.5);
		background: rgb(var(--color-surface));
	}

	/* Bottom strip: subtle separation */
	.footer__bottom {
		background: rgb(var(--color-bg) / 0.5);
		border: 1px solid rgb(var(--color-border) / 0.5);
		border-top: 1px solid rgb(var(--color-border) / 0.4);
		padding: 1rem 0;
	}

	.footer__container--bottom {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
	}

	.footer__copy {
		font-size: 0.8125rem;
		color: rgb(var(--color-muted));
		margin: 0;
	}

	.footer__back {
		font-size: 0.8125rem;
		font-weight: 500;
		color: rgb(var(--color-muted));
		text-decoration: none;
		transition: color 0.2s ease;
	}
	.footer__back:hover,
	.footer__back:focus-visible {
		color: rgb(var(--color-accent));
	}

	@media (prefers-reduced-motion: reduce) {
		.footer__name,
		.footer__link,
		.footer__social-link,
		.footer__back {
			transition: none;
		}
		.footer__link::after {
			transition: none;
		}
	}
</style>
