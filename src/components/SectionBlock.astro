---
interface Props {
	title?: string;
	eyebrow?: string;
}

const { title, eyebrow } = Astro.props;
---

<section class='section-block py-10 md:py-16 border-t border-border/70'>
	<div class='container mx-auto'>
		{
			(eyebrow || title) && (
				<header class='mb-8'>
					{eyebrow && (
						<p class='section-block__eyebrow text-sm uppercase tracking-[0.3em] text-muted'>
							{eyebrow}
						</p>
					)}
					{title && (
						<h2 class='section-block__title text-2xl md:text-3xl font-semibold font-display mt-2'>
							{title}
						</h2>
					)}
				</header>
			)
		}
		<slot />
	</div>
</section>
